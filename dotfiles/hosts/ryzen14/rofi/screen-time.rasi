@theme "~/.config/rofi/theme.rasi"

* {
  /* Unified colors from system theme variables */
  window-border:    @accent;
  card-bg:          @mantle;
  card-alt:         @base;
  card-border:      @card-bg;
  card-muted:       @subtext;
  list-alt:         @base;
  
  /* Accent background for the focus card (Card 4) */
  accent-card-bg:   @accent;
  accent-card-text: @base;
}

window {
  width:            84%;
  height:           92%;
  border:           2px;
  border-radius:    8px;
  border-color:     @window-border;
  background-color: @base;
  padding:          12px;
}

mainbox {
  orientation:      vertical;
  spacing:          12px;
  children:         [ header-box, overview-box, analytics-box, note-box, listview ];
  background-color: transparent;
}

inputbar { enabled: false; }

/* ── Header ─────────────────────────────────────────────── */

header-box {
  expand:      false;
  orientation: horizontal;
  spacing:     16px;
  children:    [ title-group, meta-group ];
}

title-group {
  orientation: vertical;
  expand:      true;
  spacing:     4px;
  children:    [ textbox-title, textbox-subtitle ];
}

meta-group {
  orientation:      vertical;
  expand:           false;
  padding:          10px 12px;
  border:           1px;
  border-radius:    8px;
  border-color:     @card-border;
  background-color: @mantle;
  children:         [ textbox-meta ];
}

textbox-title {
  markup:    true;
  text-color: @text;
  font:      "JetBrainsMono Nerd Font Bold 22";
}

textbox-subtitle {
  markup:    true;
  text-color: @subtext;
  font:      "JetBrainsMono Nerd Font 12";
}

textbox-meta {
  markup:          true;
  text-color:      @subtext;
  font:            "JetBrainsMono Nerd Font 10";
  horizontal-align: 1.0;
  line-height:     1.4;
}

/* ── Overview cards ──────────────────────────────────────── */

overview-box {
  expand:      false;
  orientation: horizontal;
  spacing:     8px;
  children:    [ card-1, card-2, card-3, card-4 ];
}

card-1, card-2, card-3 {
  orientation:      vertical;
  expand:           true;
  padding:          10px;
  spacing:          6px;
  border:           1px;
  border-radius:    8px;
  border-color:     @card-border;
  background-color: @mantle;
}

card-1 { children: [ textbox-card-1-label, textbox-card-1-value, textbox-card-1-sub ]; }
card-2 { children: [ textbox-card-2-label, textbox-card-2-value, textbox-card-2-sub ]; }
card-3 { children: [ textbox-card-3-label, textbox-card-3-value, textbox-card-3-sub ]; }

/* Card 4 uses the accent color for higher priority (Momentum / Study info) */
card-4 {
  orientation:      vertical;
  expand:           true;
  padding:          10px;
  spacing:          6px;
  border:           1px;
  border-radius:    8px;
  border-color:     @accent;
  background-color: @mantle;
  children:         [ textbox-card-4-label, textbox-card-4-value, textbox-card-4-sub ];
}

textbox-card-1-label,
textbox-card-2-label,
textbox-card-3-label,
textbox-card-4-label,
textbox-primary-title,
textbox-chart-b-title,
textbox-chart-c-title,
textbox-insight-title {
  markup:     true;
  expand:     false;
  text-color: @subtext;
  font:       "JetBrainsMono Nerd Font 11";
}

textbox-card-1-value,
textbox-card-2-value,
textbox-card-3-value {
  markup:     true;
  expand:     true;
  text-color: @text;
  font:       "JetBrainsMono Nerd Font Bold 20";
}

/* Highlighted card value */
textbox-card-4-value {
  markup:     true;
  expand:     true;
  text-color: @accent;
  font:       "JetBrainsMono Nerd Font Bold 20";
}

textbox-card-1-sub,
textbox-card-2-sub,
textbox-card-3-sub,
textbox-card-4-sub {
  markup:     true;
  expand:     false;
  text-color: @subtext;
  font:       "JetBrainsMono Nerd Font 10";
}

/* ── Analytics split ─────────────────────────────────────── */

analytics-box {
  expand:      true;
  orientation: horizontal;
  spacing:     10px;
  children:    [ primary-panel, side-panel ];
}

primary-panel {
  orientation:      vertical;
  width:            65%;
  padding:          16px;
  spacing:          10px;
  border:           1px;
  border-radius:    8px;
  border-color:     @card-border;
  background-color: @mantle;
  children:         [ textbox-primary-title, textbox-primary-body ];
}

textbox-primary-body {
  markup:      true;
  expand:      true;
  text-color:  @text;
  font:        "JetBrainsMono Nerd Font 12";
  line-height: 1.4;
}

side-panel {
  orientation: vertical;
  expand:      true;
  spacing:     10px;
  children:    [ chart-b, chart-c, insight-box ];
}

chart-b, chart-c, insight-box {
  orientation:      vertical;
  expand:           false;
  padding:          12px 14px;
  spacing:          8px;
  border:           1px;
  border-radius:    8px;
  border-color:     @card-border;
  background-color: @mantle;
}

chart-b     { children: [ textbox-chart-b-title, textbox-chart-b-body ]; }
chart-c     { children: [ textbox-chart-c-title, textbox-chart-c-body ]; }
insight-box { children: [ textbox-insight-title, textbox-insight-body ]; }
insight-box { expand: true; }

textbox-chart-b-body,
textbox-chart-c-body {
  markup:      true;
  expand:      false;
  text-color:  @text;
  font:        "JetBrainsMono Nerd Font 10";
  line-height: 1.4;
}

textbox-insight-body {
  markup:      true;
  expand:      true;
  text-color:  @text;
  font:        "JetBrainsMono Nerd Font 10";
  line-height: 1.6;
}

/* ── Note bar ────────────────────────────────────────────── */

note-box {
  expand:           false;
  padding:          10px 12px;
  border:           1px;
  border-radius:    8px;
  border-color:     @card-border;
  background-color: @mantle;
  children:         [ textbox-note ];
}

textbox-note {
  markup:     true;
  text-color: @subtext;
  font:       "JetBrainsMono Nerd Font 10";
  line-height: 1.4;
}

/* ── App list ────────────────────────────────────────────── */

listview {
  expand:           false;
  columns:          2;
  lines:            5;
  fixed-height:     true;
  spacing:          8px;
  scrollbar:        false;
  background-color: transparent;
}

element {
  orientation:      horizontal;
  children:         [ element-icon, element-text ];
  spacing:          8px;
  padding:          4px 12px;
  border:           1px;
  border-radius:    14px;
  border-color:     rgba(255, 255, 255, 0.05);
  background-color: rgba(255, 255, 255, 0.03);
  text-color:       @text;
}

element selected {
  background-color: @accent;
  text-color:       @base;
}

element-icon {
  size:             1.2em;
  vertical-align:   0.5;
  background-color: transparent;
}

element-text {
  markup:         true;
  text-color:     inherit;
  font:           "JetBrainsMono Nerd Font 11";
  vertical-align: 0.0;
}
