#!/usr/bin/env bash
set -euo pipefail

export PATH="/run/current-system/sw/bin:/etc/profiles/per-user/${USER:-$(id -un)}/bin:${HOME}/.nix-profile/bin:${PATH}"

SCREEN_TIME_CACHE_HOME="${SCREEN_TIME_CACHE_HOME:-${HOME}/.cache/rofi-screen-time}"
STATS_BIN="${STATS_BIN:-${HOME}/.local/bin/rofi-screen-time-stats}"
CACHE_DIR="${SCREEN_TIME_CACHE_HOME}/popup-cache"
TARGET_DATE="$(date +%F)"

theme_file() {
  printf '%s/default-day-theme.rasi\n' "$CACHE_DIR"
}

rows_file() {
  printf '%s/default-day-rows.txt\n' "$CACHE_DIR"
}

date_file() {
  printf '%s/default-day-date.txt\n' "$CACHE_DIR"
}

mkdir -p "$CACHE_DIR"

date_tmp="$(mktemp "${CACHE_DIR}/date.XXXXXX")"

"$STATS_BIN" \
  --view day \
  --date "$TARGET_DATE" \
  --format files \
  --theme-file "$(theme_file)" \
  --rows-file "$(rows_file)"
printf '%s\n' "$TARGET_DATE" >"$date_tmp"

mv "$date_tmp" "$(date_file)"
