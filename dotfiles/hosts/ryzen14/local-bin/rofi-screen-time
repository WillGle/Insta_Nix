#!/usr/bin/env bash
set -euo pipefail

export PATH="/run/current-system/sw/bin:/etc/profiles/per-user/${USER:-$(id -un)}/bin:${HOME}/.nix-profile/bin:${PATH}"

ROFI_CONFIG="${HOME}/.config/rofi/config.rasi"
ROFI_THEME="${HOME}/.config/rofi/screen-time.rasi"
STATS_BIN="${STATS_BIN:-${HOME}/.local/bin/rofi-screen-time-stats}"
SCREEN_TIME_CACHE_HOME="${SCREEN_TIME_CACHE_HOME:-${HOME}/.cache/rofi-screen-time}"
CACHE_BIN="${CACHE_BIN:-${HOME}/.local/bin/rofi-screen-time-cache}"
CACHE_DIR="${SCREEN_TIME_CACHE_HOME}/popup-cache"

VIEW="day"
TARGET_DATE="$(date +%F)"
APP_FILTER=""

usage() {
  cat <<'EOF'
Usage: rofi-screen-time [--date YYYY-MM-DD] [--view day|week|app] [--app APP_CLASS]
EOF
}

normalize_class() {
  local value="${1,,}"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  value="${value%.exe}"
  value="${value%-updater}"
  value="${value%_updater}"
  value="${value% updater}"
  printf '%s\n' "$value"
}

default_theme_cache_file() {
  printf '%s/default-day-theme.rasi\n' "$CACHE_DIR"
}

default_rows_cache_file() {
  printf '%s/default-day-rows.txt\n' "$CACHE_DIR"
}

default_date_cache_file() {
  printf '%s/default-day-date.txt\n' "$CACHE_DIR"
}

can_use_default_cache() {
  local today
  today="$(date +%F)"
  [ "$VIEW" = "day" ] || return 1
  [ "$TARGET_DATE" = "$today" ] || return 1
  [ -z "$APP_FILTER" ] || return 1
  [ -r "$(default_theme_cache_file)" ] || return 1
  [ -r "$(default_rows_cache_file)" ] || return 1
  [ -r "$(default_date_cache_file)" ] || return 1
  [ "$(cat "$(default_date_cache_file)" 2>/dev/null)" = "$today" ]
}

refresh_default_cache_async() {
  if [ -x "$CACHE_BIN" ]; then
    setsid -f "$CACHE_BIN" >/dev/null 2>&1 || true
  fi
}

write_default_cache() {
  local theme_str="$1"
  local rows_file="$2"
  local today
  local theme_tmp=""
  local rows_tmp=""
  local date_tmp=""

  today="$(date +%F)"
  mkdir -p "$CACHE_DIR"
  theme_tmp="$(mktemp "${CACHE_DIR}/theme.XXXXXX")"
  rows_tmp="$(mktemp "${CACHE_DIR}/rows.XXXXXX")"
  date_tmp="$(mktemp "${CACHE_DIR}/date.XXXXXX")"

  printf '%s' "$theme_str" >"$theme_tmp"
  cat "$rows_file" >"$rows_tmp"
  printf '%s\n' "$today" >"$date_tmp"

  mv "$theme_tmp" "$(default_theme_cache_file)"
  mv "$rows_tmp" "$(default_rows_cache_file)"
  mv "$date_tmp" "$(default_date_cache_file)"
}

is_default_today_view() {
  local today
  today="$(date +%F)"
  [ "$VIEW" = "day" ] && [ "$TARGET_DATE" = "$today" ] && [ -z "$APP_FILTER" ]
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --date)
      TARGET_DATE="${2:-}"
      shift 2
      ;;
    --view)
      VIEW="${2:-}"
      shift 2
      ;;
    --app)
      APP_FILTER="$(normalize_class "${2:-}")"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

TARGET_DATE="$(date -d "$TARGET_DATE" +%F 2>/dev/null || date +%F)"

while :; do
  stats_args=(--view "$VIEW" --date "$TARGET_DATE")
  if [ -n "$APP_FILTER" ]; then
    stats_args+=(--app "$APP_FILTER")
  fi
  theme_str=""
  rows_file=""
  rows_tmp=""

  if can_use_default_cache; then
    theme_str="$(cat "$(default_theme_cache_file)")"
    rows_file="$(default_rows_cache_file)"
    refresh_default_cache_async
  else
    theme_tmp="$(mktemp)"
    rows_tmp="$(mktemp)"
    "$STATS_BIN" "${stats_args[@]}" --format files --theme-file "$theme_tmp" --rows-file "$rows_tmp"
    theme_str="$(cat "$theme_tmp")"
    rows_file="$rows_tmp"
    if is_default_today_view; then
      write_default_cache "$theme_str" "$rows_file"
    fi
    rm -f "$theme_tmp"
  fi

  if ! selection="$(
    cat "$rows_file" \
      | rofi -dmenu -markup-rows -show-icons -no-custom \
          -config "$ROFI_CONFIG" \
          -theme "$ROFI_THEME" \
          -theme-str "$theme_str" \
          -p ""
  )"; then
    if [ -n "$rows_tmp" ] && [ -f "$rows_tmp" ]; then
      rm -f "$rows_tmp"
    fi
    exit 0
  fi

  if [ -n "$rows_tmp" ] && [ -f "$rows_tmp" ]; then
    rm -f "$rows_tmp"
  fi

  case "$selection" in
    close|"")
      exit 0
      ;;
    view:day:*)
      VIEW="day"
      TARGET_DATE="${selection#view:day:}"
      APP_FILTER=""
      ;;
    view:week:*)
      VIEW="week"
      TARGET_DATE="${selection#view:week:}"
      APP_FILTER=""
      ;;
    app:*)
      VIEW="app"
      APP_FILTER="${selection#app:}"
      APP_FILTER="${APP_FILTER%:*}"
      TARGET_DATE="${selection##*:}"
      ;;
    nav:prev-day-app:*)
      VIEW="app"
      TARGET_DATE="$(printf '%s' "$selection" | cut -d: -f3)"
      APP_FILTER="$(printf '%s' "$selection" | cut -d: -f4)"
      ;;
    nav:next-day-app:*)
      VIEW="app"
      TARGET_DATE="$(printf '%s' "$selection" | cut -d: -f3)"
      APP_FILTER="$(printf '%s' "$selection" | cut -d: -f4)"
      ;;
    nav:prev-day:*)
      VIEW="$VIEW"
      TARGET_DATE="${selection#nav:prev-day:}"
      TARGET_DATE="${TARGET_DATE%%:*}"
      ;;
    nav:next-day:*)
      VIEW="$VIEW"
      TARGET_DATE="${selection#nav:next-day:}"
      TARGET_DATE="${TARGET_DATE%%:*}"
      ;;
    nav:prev-week:*)
      VIEW="week"
      TARGET_DATE="${selection#nav:prev-week:}"
      APP_FILTER=""
      ;;
    nav:next-week:*)
      VIEW="week"
      TARGET_DATE="${selection#nav:next-week:}"
      APP_FILTER=""
      ;;
    refresh:day:*|refresh:week:*|refresh:app:*)
      :
      ;;
    *)
      exit 0
      ;;
  esac
done
