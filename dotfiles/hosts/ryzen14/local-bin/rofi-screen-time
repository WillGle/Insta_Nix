#!/usr/bin/env bash
set -euo pipefail

resolve_screen_time_lib_dir() {
  local script_dir
  local candidate=""
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

  for candidate in \
    "${SCREEN_TIME_LIB_DIR:-}" \
    "${SCREEN_TIME_LIB_HOME:-${HOME}/.local/lib/rofi-screen-time}/lib" \
    "$script_dir/../../common/rofi-screen-time/lib" \
    "/etc/nixos/dotfiles/common/rofi-screen-time/lib"
  do
    [ -n "$candidate" ] || continue
    if [ -r "$candidate/common.sh" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'rofi-screen-time: unable to locate rofi-screen-time libs\n' >&2
  return 1
}

SCREEN_TIME_LIB_DIR="$(resolve_screen_time_lib_dir)"
# shellcheck source=/dev/null
. "$SCREEN_TIME_LIB_DIR/common.sh"

ROFI_CONFIG="${HOME}/.config/rofi/config.rasi"
ROFI_THEME="${HOME}/.config/rofi/screen-time.rasi"
STATS_BIN="${STATS_BIN:-${HOME}/.local/bin/rofi-screen-time-stats}"
CACHE_BIN="${CACHE_BIN:-${HOME}/.local/bin/rofi-screen-time-cache}"
CACHE_DIR="${SCREEN_TIME_CACHE_HOME}/popup-cache"

VIEW="summary"
TARGET_DATE="$(date +%F)"
APP_FILTER=""

usage() {
  cat <<'EOF'
Usage: rofi-screen-time [--date YYYY-MM-DD] [--view summary|categories|focus|windows|trend|recommendations|quality]
EOF
}

default_theme_cache_file() {
  printf '%s/default-summary-theme.rasi\n' "$CACHE_DIR"
}

default_rows_cache_file() {
  printf '%s/default-summary-rows.txt\n' "$CACHE_DIR"
}

default_date_cache_file() {
  printf '%s/default-summary-date.txt\n' "$CACHE_DIR"
}

can_use_default_cache() {
  local today
  today="$(date +%F)"
  [ "$VIEW" = "summary" ] || return 1
  [ "$TARGET_DATE" = "$today" ] || return 1
  [ -r "$(default_theme_cache_file)" ] || return 1
  [ -r "$(default_rows_cache_file)" ] || return 1
  [ -r "$(default_date_cache_file)" ] || return 1
  [ "$(cat "$(default_date_cache_file)" 2>/dev/null)" = "$today" ]
}

refresh_default_cache_async() {
  if [ -x "$CACHE_BIN" ]; then
    setsid -f "$CACHE_BIN" >/dev/null 2>&1 || true
  fi
}

write_default_cache() {
  local theme_str="$1"
  local rows_file="$2"
  local today
  local theme_tmp=""
  local rows_tmp=""
  local date_tmp=""

  today="$(date +%F)"
  mkdir -p "$CACHE_DIR"
  theme_tmp="$(mktemp "${CACHE_DIR}/theme.XXXXXX")"
  rows_tmp="$(mktemp "${CACHE_DIR}/rows.XXXXXX")"
  date_tmp="$(mktemp "${CACHE_DIR}/date.XXXXXX")"

  printf '%s' "$theme_str" >"$theme_tmp"
  cat "$rows_file" >"$rows_tmp"
  printf '%s\n' "$today" >"$date_tmp"

  mv "$theme_tmp" "$(default_theme_cache_file)"
  mv "$rows_tmp" "$(default_rows_cache_file)"
  mv "$date_tmp" "$(default_date_cache_file)"
}

is_default_today_view() {
  local today
  today="$(date +%F)"
  [ "$VIEW" = "summary" ] && [ "$TARGET_DATE" = "$today" ]
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --date)
      TARGET_DATE="${2:-}"
      shift 2
      ;;
    --view)
      VIEW="${2:-}"
      shift 2
      ;;
    --app)
      APP_FILTER="$(normalize_class "${2:-}")"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

TARGET_DATE="$(date -d "$TARGET_DATE" +%F 2>/dev/null || date +%F)"
if ! VIEW="$(resolve_screen_time_view "$VIEW")"; then
  printf 'rofi-screen-time: invalid view %s\n' "$VIEW" >&2
  exit 2
fi
if [ -n "$APP_FILTER" ]; then
  printf 'rofi-screen-time: --app is retained for compatibility but ignored in the redesigned UI\n' >&2
fi

while :; do
  local_theme_file=""
  local_rows_file=""
  theme_str=""
  rows_file=""

  if can_use_default_cache; then
    theme_str="$(cat "$(default_theme_cache_file)")"
    rows_file="$(default_rows_cache_file)"
    refresh_default_cache_async
  else
    local_theme_file="$(mktemp)"
    local_rows_file="$(mktemp)"
    "$STATS_BIN" --view "$VIEW" --date "$TARGET_DATE" --format files --theme-file "$local_theme_file" --rows-file "$local_rows_file"
    theme_str="$(cat "$local_theme_file")"
    rows_file="$local_rows_file"
    if is_default_today_view; then
      write_default_cache "$theme_str" "$rows_file"
    fi
    rm -f "$local_theme_file"
  fi

  if ! selection="$(
    cat "$rows_file" \
      | rofi -dmenu -markup-rows -show-icons -no-custom \
          -config "$ROFI_CONFIG" \
          -theme "$ROFI_THEME" \
          -theme-str "$theme_str" \
          -p ""
  )"; then
    if [ -n "$local_rows_file" ] && [ -f "$local_rows_file" ]; then
      rm -f "$local_rows_file"
    fi
    exit 0
  fi

  if [ -n "$local_rows_file" ] && [ -f "$local_rows_file" ]; then
    rm -f "$local_rows_file"
  fi

  case "$selection" in
    close|"")
      exit 0
      ;;
    view:*:*)
      VIEW="${selection#view:}"
      VIEW="${VIEW%%:*}"
      TARGET_DATE="${selection##*:}"
      ;;
    nav:prev-day:*)
      TARGET_DATE="$(printf '%s' "$selection" | cut -d: -f3)"
      VIEW="$(printf '%s' "$selection" | cut -d: -f4)"
      ;;
    nav:next-day:*)
      TARGET_DATE="$(printf '%s' "$selection" | cut -d: -f3)"
      VIEW="$(printf '%s' "$selection" | cut -d: -f4)"
      ;;
    refresh:*)
      :
      ;;
    *)
      exit 0
      ;;
  esac
done
