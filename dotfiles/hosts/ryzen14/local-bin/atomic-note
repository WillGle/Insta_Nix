#!/usr/bin/env bash
set -euo pipefail

TASK_FILE="${HOME}/.atomic_tasks"
ROFI_CONFIG="${HOME}/.config/rofi/config.rasi"
THEME_STATIC_ENV="${HOME}/.config/theme/static.env"

touch "$TASK_FILE"

if [ -r "$THEME_STATIC_ENV" ]; then
  # shellcheck disable=SC1090
  . "$THEME_STATIC_ENV"
fi

ACTION_FG="${THEME_STATIC_BASE:-#11111b}"
ACTION_ADD_BG="${THEME_STATIC_ACCENT:-#89b4fa}"
ACTION_OPEN_BG="${THEME_STATIC_CYAN:-#74c7ec}"
ACTION_CLEAR_BG="${THEME_STATIC_ERROR:-#f38ba8}"
ACTION_EDIT_BG="${THEME_STATIC_PURPLE:-#cba6f7}"
ACTION_MOVE_BG="${THEME_STATIC_WARNING:-#fab387}"
ACTION_CANCEL_BG="${THEME_STATIC_SUBTEXT:-#6c7086}"
SECTION_BG="${THEME_STATIC_MANTLE:-#161b22}"
SECTION_FG="${THEME_STATIC_TEXT:-#f0f6fc}"
INFO_FG="${THEME_STATIC_SUBTEXT:-#8b949e}"
TASK_CRITICAL_BG="${THEME_STATIC_ERROR:-#f38ba8}"
TASK_HIGH_BG="${THEME_STATIC_WARNING:-#fab387}"
TASK_MODERATE_BG="${THEME_STATIC_ACCENT:-#89b4fa}"
TASK_LOW_BG="${THEME_STATIC_SUCCESS:-#a6e3a1}"
CHIP_ICON_FONT_DESC="${THEME_MONO_FONT:-JetBrainsMono Nerd Font} ${THEME_MONO_FONT_SIZE:-11}"

refresh_waybar() {
  pkill -RTMIN+5 waybar >/dev/null 2>&1 || true
}

rofi_prompt() {
  local prompt="$1"
  printf '' | rofi -dmenu -p "$prompt" -config "$ROFI_CONFIG"
}

resolve_editor() {
  if [ -n "${EDITOR:-}" ]; then
    printf '%s\n' "$EDITOR"
    return 0
  fi

  if command -v nano >/dev/null 2>&1; then
    printf '%s\n' "nano"
    return 0
  fi

  printf '%s\n' "vi"
}

trim_whitespace() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

normalize_priority() {
  local raw="${1:-moderate}"
  raw="$(trim_whitespace "${raw,,}")"
  case "$raw" in
    critical|crit|p0|a)
      printf '%s\n' "critical"
      ;;
    high|p1|b)
      printf '%s\n' "high"
      ;;
    moderate|medium|med|normal|default|p2|c|"")
      printf '%s\n' "moderate"
      ;;
    low|p3|d)
      printf '%s\n' "low"
      ;;
    *)
      return 1
      ;;
  esac
}

priority_label() {
  case "$1" in
    critical)
      printf '%s\n' "Critical"
      ;;
    high)
      printf '%s\n' "High"
      ;;
    moderate)
      printf '%s\n' "Moderate"
      ;;
    low)
      printf '%s\n' "Low"
      ;;
  esac
}

priority_icon() {
  case "$1" in
    critical)
      printf '%s\n' "◆"
      ;;
    high)
      printf '%s\n' "▲"
      ;;
    moderate)
      printf '%s\n' "●"
      ;;
    low)
      printf '%s\n' "○"
      ;;
  esac
}

priority_bg() {
  case "$1" in
    critical)
      printf '%s\n' "$TASK_CRITICAL_BG"
      ;;
    high)
      printf '%s\n' "$TASK_HIGH_BG"
      ;;
    moderate)
      printf '%s\n' "$TASK_MODERATE_BG"
      ;;
    low)
      printf '%s\n' "$TASK_LOW_BG"
      ;;
  esac
}

task_priority() {
  local task="$1"
  local lower="${task,,}"
  case "$lower" in
    \[critical\]*|\[a\]*)
      printf '%s\n' "critical"
      ;;
    \[high\]*|\[b\]*)
      printf '%s\n' "high"
      ;;
    \[moderate\]*|\[medium\]*|\[c\]*)
      printf '%s\n' "moderate"
      ;;
    \[low\]*|\[d\]*)
      printf '%s\n' "low"
      ;;
    *)
      printf '%s\n' "moderate"
      ;;
  esac
}

task_body() {
  local task="$1"
  if [[ "$task" =~ ^\[(Critical|High|Moderate|Medium|Low|A|B|C|D)\][[:space:]]*(.*)$ ]]; then
    printf '%s\n' "${BASH_REMATCH[2]}"
    return 0
  fi
  printf '%s\n' "$task"
}

format_task() {
  local body="$1"
  local priority="$2"
  body="$(trim_whitespace "$body")"
  if [ -z "$body" ]; then
    return 1
  fi
  printf '[%s] %s\n' "$(priority_label "$priority")" "$body"
}

escape_markup() {
  local value="${1//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  printf '%s\n' "$value"
}

rasi_quote() {
  jq -Rn --arg value "$1" '$value'
}

chip_label() {
  local icon="$1"
  local bg="$2"
  local label="$3"
  printf '<span bgcolor="%s" foreground="%s"><span font_desc="%s"> %s </span></span>  %s\n' \
    "$bg" \
    "$ACTION_FG" \
    "$(escape_markup "$CHIP_ICON_FONT_DESC")" \
    "$icon" \
    "$(escape_markup "$label")"
}

icon_chip() {
  local icon="$1"
  local bg="$2"
  printf '<span bgcolor="%s" foreground="%s"><span font_desc="%s"> %s </span></span>\n' \
    "$bg" \
    "$ACTION_FG" \
    "$(escape_markup "$CHIP_ICON_FONT_DESC")" \
    "$icon"
}

section_label() {
  local label="$1"
  printf '<span bgcolor="%s" foreground="%s"> %s </span>\n' \
    "$SECTION_BG" \
    "$SECTION_FG" \
    "$(escape_markup "$label")"
}

empty_cell() {
  printf '<span foreground="%s"> </span>\n' "$SECTION_BG"
}

empty_task_label() {
  printf '<span foreground="%s" weight="600">No active tasks</span>  <span foreground="%s" size="small">Nothing pending</span>\n' \
    "$SECTION_FG" \
    "$INFO_FG"
}

task_label() {
  local task="$1"
  local priority
  local body
  priority="$(task_priority "$task")"
  body="$(task_body "$task")"
  printf '%s  <span weight="600">%s</span>  <span foreground="%s" size="small">%s priority</span>\n' \
    "$(icon_chip "$(priority_icon "$priority")" "$(priority_bg "$priority")")" \
    "$(escape_markup "$body")" \
    "$INFO_FG" \
    "$(priority_label "$priority")"
}

select_priority() {
  local prompt="$1"
  local default_priority="${2:-moderate}"
  local empty_mode="${3:-default}"
  local critical_option
  local high_option
  local moderate_option
  local low_option
  local selection

  critical_option="$(chip_label "$(priority_icon critical)" "$(priority_bg critical)" "Critical")"
  high_option="$(chip_label "$(priority_icon high)" "$(priority_bg high)" "High")"
  moderate_option="$(chip_label "$(priority_icon moderate)" "$(priority_bg moderate)" "Moderate")"
  low_option="$(chip_label "$(priority_icon low)" "$(priority_bg low)" "Low")"

  selection="$(
    printf '%s\n%s\n%s\n%s\n' \
      "$critical_option" \
      "$high_option" \
      "$moderate_option" \
      "$low_option" \
      | rofi -dmenu -i -markup-rows -p "$prompt" -config "$ROFI_CONFIG"
  )"

  case "$selection" in
    "$critical_option")
      printf '%s\n' "critical"
      ;;
    "$high_option")
      printf '%s\n' "high"
      ;;
    "$moderate_option")
      printf '%s\n' "moderate"
      ;;
    "$low_option")
      printf '%s\n' "low"
      ;;
    "")
      if [ "$empty_mode" = "empty" ]; then
        printf '%s\n' ""
      else
        printf '%s\n' "$default_priority"
      fi
      ;;
    *)
      if [ "$empty_mode" = "empty" ]; then
        printf '%s\n' ""
      else
        printf '%s\n' "$default_priority"
      fi
      ;;
  esac
}

read_tasks() {
  mapfile -t TASKS < "$TASK_FILE"
}

write_tasks() {
  printf '%s\n' "$@" > "$TASK_FILE"
}

render_waybar() {
  read_tasks

  local count="${#TASKS[@]}"
  if [ "$count" -eq 0 ]; then
    jq -cn \
      --arg text "󰠮 Empty" \
      --arg tooltip "No active tasks" \
      --arg class "empty" \
      '{text: $text, tooltip: $tooltip, class: $class}'
    return 0
  fi

  local top_task="${TASKS[0]}"
  local remaining=$((count - 1))
  local top_priority
  local top_body
  local top_icon
  local display_text
  local tooltip
  local priority
  local body
  local i

  top_priority="$(task_priority "$top_task")"
  top_body="$(task_body "$top_task")"
  top_icon="$(priority_icon "$top_priority")"
  display_text="[$top_icon] $top_body"
  if [ "$remaining" -gt 0 ]; then
    display_text="$display_text   ($remaining)"
  fi

  tooltip="<b><span foreground='${THEME_STATIC_ACCENT:-#58a6ff}'>ATOMIC TASKS</span></b>
<span alpha='30%'>──────────────────────────</span>
<tt>"
  for ((i = 0; i < 5 && i < count; i++)); do
    priority="$(task_priority "${TASKS[$i]}")"
    body="$(task_body "${TASKS[$i]}")"
    color="$(priority_bg "$priority")"
    tooltip+="<span foreground='$color'>$(priority_icon "$priority")</span> [$(priority_label "$priority")] $(escape_markup "$body")"$'\n'
  done

  if [ "$count" -gt 5 ]; then
    tooltip+="... and $((count - 5)) more"
  fi
  tooltip+="</tt>"

  jq -cn \
    --arg text "$display_text" \
    --arg tooltip "$tooltip" \
    --arg class "$top_priority" \
    '{text: $text, tooltip: $tooltip, class: $class}'
}

add_task() {
  local note="${1:-}"
  local priority_input="${2:-}"
  local priority=""
  if [ -z "$note" ]; then
    note="$(rofi_prompt "Task:")"
    note="$(trim_whitespace "$note")"
    if [ -z "$note" ]; then
      return 0
    fi
    if [ -n "$priority_input" ] && priority="$(normalize_priority "$priority_input" 2>/dev/null)"; then
      :
    else
      priority="$(select_priority "Priority:" "moderate" "empty")"
      if [ -z "$priority" ]; then
        return 0
      fi
    fi
  else
    note="$(trim_whitespace "$note")"
    if [ -z "$note" ]; then
      return 0
    fi
    if priority="$(normalize_priority "$priority_input" 2>/dev/null)"; then
      :
    else
      priority="$(task_priority "$note")"
      note="$(trim_whitespace "$(task_body "$note")")"
    fi
  fi

  local formatted
  formatted="$(format_task "$note" "$priority")" || return 0
  printf '%s\n' "$formatted" >> "$TASK_FILE"
  refresh_waybar
}

open_file_in_terminal() {
  local editor_cmd
  editor_cmd="$(resolve_editor)"
  foot -e sh -lc 'exec "$@"' sh $editor_cmd "$TASK_FILE" >/dev/null 2>&1 &
}

list_tasks() {
  cat "$TASK_FILE"
}

clear_tasks() {
  : > "$TASK_FILE"
  refresh_waybar
}

delete_task_by_index() {
  local index="$1"
  read_tasks
  if [ "$index" -lt 0 ] || [ "$index" -ge "${#TASKS[@]}" ]; then
    return 1
  fi

  unset 'TASKS[index]'
  if [ "${#TASKS[@]}" -eq 0 ]; then
    : > "$TASK_FILE"
  else
    write_tasks "${TASKS[@]}"
  fi
  refresh_waybar
}

move_task_to_top() {
  local index="$1"
  read_tasks
  if [ "$index" -lt 0 ] || [ "$index" -ge "${#TASKS[@]}" ]; then
    return 1
  fi

  local selected="${TASKS[$index]}"
  unset 'TASKS[index]'
  write_tasks "$selected" "${TASKS[@]}"
  refresh_waybar
}

edit_task_by_index() {
  local index="$1"
  read_tasks
  if [ "$index" -lt 0 ] || [ "$index" -ge "${#TASKS[@]}" ]; then
    return 1
  fi

  local current="${TASKS[$index]}"
  local current_body
  local current_priority
  current_body="$(task_body "$current")"
  current_priority="$(task_priority "$current")"
  local updated
  updated="$(printf '%s' "$current_body" | rofi -dmenu -p "Edit Task:" -config "$ROFI_CONFIG")"
  if [ -z "$updated" ]; then
    return 0
  fi

  TASKS[$index]="$(format_task "$updated" "$current_priority")"
  write_tasks "${TASKS[@]}"
  refresh_waybar
}

change_priority_by_index() {
  local index="$1"
  read_tasks
  if [ "$index" -lt 0 ] || [ "$index" -ge "${#TASKS[@]}" ]; then
    return 1
  fi

  local current="${TASKS[$index]}"
  local current_body
  local current_priority
  local updated_priority
  current_body="$(task_body "$current")"
  current_priority="$(task_priority "$current")"
  updated_priority="$(select_priority "Priority:" "$current_priority")"
  TASKS[$index]="$(format_task "$current_body" "$updated_priority")"
  write_tasks "${TASKS[@]}"
  refresh_waybar
}

confirm_clear() {
  local choice
  local no_option
  local yes_option
  no_option="$(chip_label "󰜺" "$ACTION_CANCEL_BG" "No")"
  yes_option="$(chip_label "󰄬" "$ACTION_CLEAR_BG" "Yes, clear all")"

  choice="$(
    printf '%s\n%s\n' "$no_option" "$yes_option" \
      | rofi -dmenu -i -markup-rows -p "Clear all tasks?" -config "$ROFI_CONFIG"
  )"
  [ "$choice" = "$yes_option" ]
}

task_menu() {
  local index="$1"
  local task="$2"
  local choice
  local done_option
  local edit_option
  local priority_option
  local move_option
  local cancel_option

  done_option="$(chip_label "󰄬" "$ACTION_ADD_BG" "Mark done")"
  edit_option="$(chip_label "󰏫" "$ACTION_EDIT_BG" "Edit task")"
  priority_option="$(chip_label "󰦨" "$ACTION_OPEN_BG" "Change priority")"
  move_option="$(chip_label "󰁝" "$ACTION_MOVE_BG" "Move to top")"
  cancel_option="$(chip_label "󰜺" "$ACTION_CANCEL_BG" "Cancel")"

  choice="$(
    printf '%s\n%s\n%s\n%s\n%s\n' \
      "$done_option" \
      "$edit_option" \
      "$priority_option" \
      "$move_option" \
      "$cancel_option" \
      | rofi -dmenu -i -markup-rows -p "Task: $(task_body "$task")" -config "$ROFI_CONFIG"
  )"

  case "$choice" in
    "$done_option")
      delete_task_by_index "$index"
      ;;
    "$edit_option")
      edit_task_by_index "$index"
      ;;
    "$priority_option")
      change_priority_by_index "$index"
      ;;
    "$move_option")
      move_task_to_top "$index"
      ;;
    *)
      ;;
  esac
}

rofi_menu() {
  while true; do
    read_tasks

    local options=()
    local hot_task_labels=()
    local low_task_labels=()
    local task_labels=()
    local hot_header
    local low_header
    local hot_rows=()
    local low_rows=()
    local task
    local display_task
    local priority
    local hot_count=0
    local low_count=0
    local total_count=0
    local row_count=0
    local menu_lines=0
    local status_text
    local i
    local left_cell
    local right_cell
    local selection=""
    local status=0
    local action_theme

    for task in "${TASKS[@]}"; do
      display_task="$(task_label "$task")"
      task_labels+=("$display_task")
      priority="$(task_priority "$task")"
      if [ "$priority" = "critical" ] || [ "$priority" = "high" ]; then
        hot_task_labels+=("$display_task")
      else
        low_task_labels+=("$display_task")
      fi
    done

    hot_rows=("${hot_task_labels[@]}")
    low_rows=("${low_task_labels[@]}")
    hot_count="${#hot_rows[@]}"
    low_count="${#low_rows[@]}"
    total_count="${#TASKS[@]}"
    hot_header="$(section_label "Critical / High  $hot_count")"
    low_header="$(section_label "Moderate / Low  $low_count")"

    if [ "$total_count" -eq 0 ]; then
      hot_rows=("$(empty_task_label)")
      hot_count=0
      low_count=0
      status_text="No active tasks"
    else
      status_text="$total_count active  •  $hot_count urgent  •  $low_count later"
    fi

    row_count="${#hot_rows[@]}"
    if [ "${#low_rows[@]}" -gt "$row_count" ]; then
      row_count="${#low_rows[@]}"
    fi
    if [ "$row_count" -lt 1 ]; then
      row_count=1
    fi
    menu_lines=$((row_count + 1))

    action_theme="$(mktemp)"
    cat > "$action_theme" <<EOF
@theme "~/.config/rofi/theme.rasi"

window {
  width: 54%;
  children: [ mainbox ];
  border-radius: 12px;
  padding: 14px;
}

mainbox {
  children: [ actionbar, inputbar, statusbar, listview ];
  spacing: 10px;
  padding: 10px;
}

statusbar {
  expand: false;
  padding: 7px 10px;
  border: 1px;
  border-radius: 8px;
  border-color: rgba(255, 255, 255, 0.10);
  background-color: ${SECTION_BG};
  children: [ textbox-status ];
}

textbox-status {
  markup: true;
  content: $(rasi_quote "$status_text");
  text-color: ${INFO_FG};
  font: "JetBrainsMono Nerd Font 10";
}

actionbar {
  expand: false;
  orientation: horizontal;
  spacing: 6px;
  children: [ button-add, button-open, button-clear ];
}

button {
  cursor: pointer;
}

button-add, button-open, button-clear {
  expand: false;
  padding: 5px 10px;
  border-radius: 8px;
  border: 1px;
  background-color: ${SECTION_BG};
  font: "JetBrainsMono Nerd Font 10";
  horizontal-align: 0.5;
}

button selected,
button selected.normal {
  text-color: ${ACTION_FG};
}

button-add {
  content: "󰐕 Add";
  text-color: ${ACTION_ADD_BG};
  border-color: ${ACTION_ADD_BG};
  action: "kb-custom-1";
}

button-add selected,
button-add selected.normal {
  background-color: ${ACTION_ADD_BG};
  text-color: ${ACTION_FG};
}

button-open {
  content: "󰈔 Open";
  text-color: ${ACTION_OPEN_BG};
  border-color: ${ACTION_OPEN_BG};
  action: "kb-custom-2";
}

button-open selected,
button-open selected.normal {
  background-color: ${ACTION_OPEN_BG};
  text-color: ${ACTION_FG};
}

button-clear {
  content: "󰩹 Clear";
  text-color: ${ACTION_CLEAR_BG};
  border-color: ${ACTION_CLEAR_BG};
  action: "kb-custom-3";
}

button-clear selected,
button-clear selected.normal {
  background-color: ${ACTION_CLEAR_BG};
  text-color: ${ACTION_FG};
}

inputbar {
  margin: 0;
  padding: 6px;
  border: 1px;
  border-radius: 8px;
  border-color: rgba(255, 255, 255, 0.08);
  background-color: ${SECTION_BG};
}

listview {
  columns: 2;
  lines: ${menu_lines};
  flow: horizontal;
  fixed-columns: true;
  fixed-height: false;
  spacing: 6px;
  padding: 0;
}

element {
  padding: 7px 10px;
  border-radius: 8px;
  spacing: 8px;
}

element selected {
  background-color: ${ACTION_ADD_BG};
  text-color: ${ACTION_FG};
}
EOF

    options+=("$hot_header" "$low_header")
    for ((i = 0; i < row_count; i++)); do
      if [ "$i" -lt "${#hot_rows[@]}" ]; then
        left_cell="${hot_rows[$i]}"
      else
        left_cell="$(empty_cell)"
      fi
      if [ "$i" -lt "${#low_rows[@]}" ]; then
        right_cell="${low_rows[$i]}"
      else
        right_cell="$(empty_cell)"
      fi
      options+=("$left_cell" "$right_cell")
    done

    selection="$(
      printf '%s\n' "${options[@]}" \
        | rofi -dmenu -i -hover-select -markup-rows -p "Atomic Tasks" \
          -kb-custom-1 "Alt+1" \
          -kb-custom-2 "Alt+2" \
          -kb-custom-3 "Alt+3" \
          -config "$ROFI_CONFIG" -theme "$action_theme"
    )" || status=$?
    rm -f "$action_theme"

    case "$status" in
      0)
        ;;
      1)
        return 0
        ;;
      10)
        add_task
        continue
        ;;
      11)
        open_file_in_terminal
        return 0
        ;;
      12)
        if confirm_clear; then
          clear_tasks
        fi
        continue
        ;;
      *)
        return 0
        ;;
    esac

    case "$selection" in
      "")
        return 0
        ;;
      "$hot_header"|"$low_header")
        continue
        ;;
      *)
        local idx=0
        local found=0
        for display_task in "${task_labels[@]}"; do
          if [ "$display_task" = "$selection" ]; then
            task_menu "$idx" "${TASKS[$idx]}"
            found=1
            break
          fi
          idx=$((idx + 1))
        done
        if [ "$found" -eq 0 ]; then
          continue
        fi
        ;;
    esac
  done
}

case "${1:-}" in
  render-waybar)
    render_waybar
    ;;
  add)
    add_task "${2:-}"
    ;;
  edit)
    rofi_menu
    ;;
  file)
    open_file_in_terminal
    ;;
  list)
    list_tasks
    ;;
  clear)
    clear_tasks
    ;;
  rofi|menu)
    rofi_menu
    ;;
  *)
    rofi_menu
    ;;
esac
