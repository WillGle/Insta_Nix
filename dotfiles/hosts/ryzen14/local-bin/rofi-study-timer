#!/usr/bin/env bash
set -euo pipefail

export PATH="/run/current-system/sw/bin:/etc/profiles/per-user/${USER:-$(id -un)}/bin:${HOME}/.nix-profile/bin:${PATH}"

ROFI_CONFIG="${HOME}/.config/rofi/config.rasi"
ROFI_THEME="${ROFI_THEME:-}"
ROFI_BIN="${ROFI_BIN:-rofi}"
TIMER_BIN="${TIMER_BIN:-${HOME}/.local/bin/study-timer}"
SCREEN_TIME_BIN="${SCREEN_TIME_BIN:-${HOME}/.local/bin/rofi-screen-time}"

resolve_rofi_theme() {
  local script_dir
  local candidate=""
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

  for candidate in \
    "${ROFI_THEME:-}" \
    "${HOME}/.config/rofi/study-timer.rasi" \
    "$script_dir/../../../common/rofi/study-timer.rasi" \
    "/etc/nixos/dotfiles/common/rofi/study-timer.rasi"
  do
    [ -n "$candidate" ] || continue
    if [ -r "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'rofi-study-timer: unable to locate study-timer theme\n' >&2
  return 1
}

ROFI_THEME="$(resolve_rofi_theme)"

escape_markup() {
  local value="${1//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  printf '%s\n' "$value"
}

emit_row() {
  local token="$1"
  local display="$2"
  local icon="${3:-}"
  printf '%s' "$token"
  printf '\0display\x1f%s' "$display"
  if [ -n "$icon" ]; then
    printf '\x1ficon\x1f%s' "$icon"
  fi
  printf '\n'
}

seconds_to_short() {
  local total="${1:-0}"
  local hours=$((total / 3600))
  local minutes=$(((total % 3600) / 60))

  if [ "$total" -gt 0 ] && [ "$hours" -eq 0 ] && [ "$minutes" -eq 0 ]; then
    printf '~1m\n'
    return 0
  fi
  if [ "$hours" -gt 0 ] && [ "$minutes" -gt 0 ]; then
    printf '%dh %dm\n' "$hours" "$minutes"
    return 0
  fi
  if [ "$hours" -gt 0 ]; then
    printf '%dh\n' "$hours"
    return 0
  fi
  printf '%dm\n' "$minutes"
}

run_rofi_menu() {
  "$ROFI_BIN" -dmenu -markup-rows -show-icons -no-custom \
    -config "$ROFI_CONFIG" \
    -theme "$ROFI_THEME" \
    -p ""
}

row_markup() {
  local title="$1"
  local subtitle="${2:-}"

  if [ -n "$subtitle" ]; then
    printf '<span weight="600">%s</span>&#10;<span size="small">%s</span>' \
      "$(escape_markup "$title")" \
      "$(escape_markup "$subtitle")"
  else
    printf '<span weight="600">%s</span>' "$(escape_markup "$title")"
  fi
}

pluralize() {
  local count="${1:-0}"
  local singular="$2"
  local plural="${3:-${2}s}"
  if [ "$count" -eq 1 ]; then
    printf '%s\n' "$singular"
    return 0
  fi
  printf '%s\n' "$plural"
}

plan_summary() {
  local duration_minutes="$1"
  local session_count="$2"
  printf '%sm • %s %s\n' \
    "$duration_minutes" \
    "$session_count" \
    "$(pluralize "$session_count" "session")"
}

active_plan_summary() {
  local json="$1"
  local duration_minutes
  local planned_sessions
  local current_session
  local remaining_total_seconds
  local target_reached

  duration_minutes="$(printf '%s' "$json" | jq -r '.duration_minutes // empty')"
  planned_sessions="$(printf '%s' "$json" | jq -r '.planned_sessions // empty')"
  current_session="$(printf '%s' "$json" | jq -r '.current_session // empty')"
  remaining_total_seconds="$(printf '%s' "$json" | jq -r '.remaining_total_seconds // empty')"
  target_reached="$(printf '%s' "$json" | jq -r '.target_reached // false')"

  if [ -z "$duration_minutes" ]; then
    printf 'Open-ended session • %s elapsed\n' "$(seconds_to_short "$elapsed_seconds")"
    return 0
  fi

  if [ "$target_reached" = "true" ]; then
    printf '%s • complete • stop to log\n' "$(plan_summary "$duration_minutes" "${planned_sessions:-1}")"
    return 0
  fi

  if [ -n "$planned_sessions" ] && [ -n "$current_session" ] && [ -n "$remaining_total_seconds" ] && [ "$remaining_total_seconds" != "null" ]; then
    printf '%s • session %s/%s • %s left\n' \
      "$(plan_summary "$duration_minutes" "$planned_sessions")" \
      "$current_session" \
      "$planned_sessions" \
      "$(seconds_to_short "$remaining_total_seconds")"
    return 0
  fi

  printf '%sm target • %s elapsed\n' "$duration_minutes" "$(seconds_to_short "$elapsed_seconds")"
}

generate_duration_rows() {
  emit_row "duration:25" "$(row_markup "25-minute block" "Quick focus")" "appointment-soon-symbolic"
  emit_row "duration:50" "$(row_markup "50-minute block" "Deep work default")" "appointment-new-symbolic"
  emit_row "duration:75" "$(row_markup "75-minute block" "Long concentration block")" "alarm-symbolic"
  emit_row "duration:90" "$(row_markup "90-minute block" "Exam or reading sprint")" "alarm-symbolic"
  emit_row "back" "$(row_markup "Back")" "go-previous-symbolic"
  emit_row "close" "$(row_markup "Close")" "window-close-symbolic"
}

generate_session_count_rows() {
  local duration_minutes="$1"
  emit_row "sessions:1" "$(row_markup "1 session" "$(plan_summary "$duration_minutes" 1)")" "view-list-symbolic"
  emit_row "sessions:2" "$(row_markup "2 sessions" "$(plan_summary "$duration_minutes" 2)")" "view-list-symbolic"
  emit_row "sessions:3" "$(row_markup "3 sessions" "$(plan_summary "$duration_minutes" 3)")" "view-list-symbolic"
  emit_row "sessions:4" "$(row_markup "4 sessions" "$(plan_summary "$duration_minutes" 4)")" "view-list-symbolic"
  emit_row "back" "$(row_markup "Back")" "go-previous-symbolic"
  emit_row "close" "$(row_markup "Close")" "window-close-symbolic"
}

choose_duration() {
  generate_duration_rows | run_rofi_menu
}

choose_session_count() {
  local duration_minutes="$1"
  generate_session_count_rows "$duration_minutes" | run_rofi_menu
}

start_planned_session() {
  local duration_minutes="$1"
  local session_count="$2"
  "$TIMER_BIN" start --duration-minutes "$duration_minutes" --session-count "$session_count" >/dev/null 2>&1
}

start_open_ended_session() {
  "$TIMER_BIN" start >/dev/null 2>&1
}

start_guided_plan() {
  local duration_selection=""
  local duration_minutes=""
  local session_selection=""
  local session_count=""

  while :; do
    duration_selection="$(choose_duration)" || return 0
    case "$duration_selection" in
      duration:*)
        duration_minutes="${duration_selection#duration:}"
        ;;
      back|close|"")
        return 0
        ;;
      *)
        return 0
        ;;
    esac

    while :; do
      session_selection="$(choose_session_count "$duration_minutes")" || return 0
      case "$session_selection" in
        sessions:*)
          session_count="${session_selection#sessions:}"
          start_planned_session "$duration_minutes" "$session_count"
          return 0
          ;;
        back)
          break
          ;;
        close|"")
          return 0
          ;;
        *)
          return 0
          ;;
      esac
    done
  done
}

status_json="$("$TIMER_BIN" status --format json)"
active="$(printf '%s' "$status_json" | jq -r '.active')"
started_at="$(printf '%s' "$status_json" | jq -r '.started_at // empty')"
elapsed_seconds="$(printf '%s' "$status_json" | jq -r '.elapsed_seconds // 0')"
elapsed_label="$("$TIMER_BIN" status | sed 's/^active //; s/^inactive$/No active study session/')"

generate_rows() {
  if [ "$active" = "true" ]; then
    emit_row "stop" "$(row_markup "Stop study session" "$elapsed_label")" "media-playback-stop-symbolic"
    emit_row "status" "$(row_markup "Current plan" "$(active_plan_summary "$status_json")")" "appointment-symbolic"
  else
    emit_row "start:preset:25:1" "$(row_markup "Quick start" "$(plan_summary 25 1)")" "media-playback-start-symbolic"
    emit_row "start:preset:25:4" "$(row_markup "Pomodoro set" "$(plan_summary 25 4)")" "media-playback-start-symbolic"
    emit_row "start:preset:50:2" "$(row_markup "Deep work set" "$(plan_summary 50 2)")" "media-playback-start-symbolic"
    emit_row "start:preset:90:1" "$(row_markup "Long block" "$(plan_summary 90 1)")" "media-playback-start-symbolic"
    emit_row "start:guided" "$(row_markup "Custom study plan" "Choose duration and session count")" "preferences-system-time-symbolic"
    emit_row "start:open" "$(row_markup "Open-ended session" "Track manually until you stop it")" "appointment-missed-symbolic"
  fi
  emit_row "screen-time" "$(row_markup "Open screen time" "Dashboard and study totals")" "view-calendar-symbolic"
  emit_row "close" "$(row_markup "Close")" "window-close-symbolic"
}

selection="$(
  generate_rows \
    | run_rofi_menu
)" || exit 0

case "$selection" in
  start:preset:*)
    duration_minutes="$(printf '%s' "$selection" | cut -d: -f3)"
    session_count="$(printf '%s' "$selection" | cut -d: -f4)"
    start_planned_session "$duration_minutes" "$session_count"
    ;;
  start:guided)
    start_guided_plan
    ;;
  start:open)
    start_open_ended_session
    ;;
  stop)
    "$TIMER_BIN" stop >/dev/null 2>&1
    ;;
  status)
    exit 0
    ;;
  screen-time)
    setsid -f "$SCREEN_TIME_BIN" >/dev/null 2>&1 || true
    ;;
  close|"")
    exit 0
    ;;
esac
