#!/usr/bin/env bash
set -euo pipefail

export PATH="/run/current-system/sw/bin:/etc/profiles/per-user/${USER:-$(id -un)}/bin:${HOME}/.nix-profile/bin:${PATH}"

ROFI_CONFIG="${HOME}/.config/rofi/config.rasi"
ROFI_THEME="${ROFI_THEME:-}"
ROFI_BIN="${ROFI_BIN:-rofi}"
TIMER_BIN="${TIMER_BIN:-${HOME}/.local/bin/study-timer}"
SCREEN_TIME_BIN="${SCREEN_TIME_BIN:-${HOME}/.local/bin/rofi-screen-time}"

resolve_rofi_theme() {
  local script_dir
  local candidate=""
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

  for candidate in \
    "${ROFI_THEME:-}" \
    "${HOME}/.config/rofi/study-timer.rasi" \
    "$script_dir/../../../common/rofi/study-timer.rasi" \
    "/etc/nixos/dotfiles/common/rofi/study-timer.rasi"
  do
    [ -n "$candidate" ] || continue
    if [ -r "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'rofi-study-timer: unable to locate study-timer theme\n' >&2
  return 1
}

ROFI_THEME="$(resolve_rofi_theme)"

escape_markup() {
  local value="${1//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  printf '%s\n' "$value"
}

emit_row() {
  local token="$1"
  local display="$2"
  local icon="${3:-}"
  printf '%s' "$token"
  printf '\0display\x1f%s' "$display"
  if [ -n "$icon" ]; then
    printf '\x1ficon\x1f%s' "$icon"
  fi
  printf '\n'
}

seconds_to_short() {
  local total="${1:-0}"
  local hours=$((total / 3600))
  local minutes=$(((total % 3600) / 60))

  if [ "$total" -gt 0 ] && [ "$hours" -eq 0 ] && [ "$minutes" -eq 0 ]; then
    printf '~1m'
    return 0
  fi
  if [ "$hours" -gt 0 ] && [ "$minutes" -gt 0 ]; then
    printf '%dh %dm' "$hours" "$minutes"
    return 0
  fi
  if [ "$hours" -gt 0 ]; then
    printf '%dh' "$hours"
    return 0
  fi
  printf '%dm' "$minutes"
}

run_rofi_menu() {
  local prompt="${1:-Study Timer}"
  local message="${2:-}"
  local args=(
    -dmenu
    -markup-rows
    -show-icons
    -no-custom
    -config "$ROFI_CONFIG"
    -theme "$ROFI_THEME"
    -p "$prompt"
  )

  if [ -n "$message" ]; then
    args+=(-mesg "$message")
  fi

  "$ROFI_BIN" "${args[@]}"
}

confirm_plan() {
  local prompt="$1"
  local message="$2"
  local start_option
  local cancel_option

  start_option="$(row_markup "Start session" "Click to begin study now")"
  cancel_option="$(row_markup "Cancel")"

  choice="$(
    printf 'start\0display\x1f%s\x1ficon\x1fmedia-playback-start-symbolic\ncancel\0display\x1f%s\x1ficon\x1fwindow-close-symbolic\n' \
      "$start_option" "$cancel_option" \
      | run_rofi_menu "$prompt" "$message"
  )"

  [ "$choice" = "start" ]
}

row_markup() {
  local title="$1"
  local subtitle="${2:-}"

  if [ -n "$subtitle" ]; then
    # We do NOT escape the subtitle because it might already contain Pango markup (e.g. from active_plan_summary).
    # However, the title should still be escaped for safety.
    printf '<span weight="600">%s</span>&#10;<span size="small">%s</span>' \
      "$(escape_markup "$title")" \
      "$subtitle"
  else
    printf '<span weight="600">%s</span>' "$(escape_markup "$title")"
  fi
}

pluralize() {
  local count="${1:-0}"
  local singular="$2"
  local plural="${3:-${2}s}"
  if [ "$count" -eq 1 ]; then
    printf '%s' "$singular"
    return 0
  fi
  printf '%s' "$plural"
}

plan_summary() {
  local duration_minutes="$1"
  local session_count="$2"
  printf '%sm • %s %s' \
    "$duration_minutes" \
    "$session_count" \
    "$(pluralize "$session_count" "session")"
}

progress_bar() {
  local value="${1:-0}"
  local max="${2:-100}"
  local width="${3:-15}"
  local filled=0
  local out=""
  local i=0

  if [ "$max" -gt 0 ]; then
    filled=$((value * width / max))
  fi

  while [ "$i" -lt "$filled" ]; do
    out+="■"
    i=$((i + 1))
  done
  while [ "$i" -lt "$width" ]; do
    out+="□"
    i=$((i + 1))
  done

  printf '[%s]' "$out"
}

format_time() {
  local iso="$1"
  [ -n "$iso" ] || return 0
  date -d "$iso" '+%H:%M'
}

active_plan_summary() {
  local json="$1"
  local duration_minutes="$(printf '%s' "$json" | jq -r '.duration_minutes // empty')"
  local planned_sessions="$(printf '%s' "$json" | jq -r '.planned_sessions // empty')"
  local current_session="$(printf '%s' "$json" | jq -r '.current_session // empty')"
  local elapsed_seconds="$(printf '%s' "$json" | jq -r '.elapsed_seconds // 0')"
  local remaining_total_seconds="$(printf '%s' "$json" | jq -r '.remaining_total_seconds // empty')"
  local current_session_elapsed_seconds="$(printf '%s' "$json" | jq -r '.current_session_elapsed_seconds // 0')"
  local per_session_seconds="$(printf '%s' "$json" | jq -r '.per_session_seconds // 0')"
  local target_reached="$(printf '%s' "$json" | jq -r '.target_reached // false')"
  local mode="$(printf '%s' "$json" | jq -r '.mode // empty')"
  local estimated_finish_at="$(printf '%s' "$json" | jq -r '.estimated_finish_at // empty')"
  local daily_total_seconds="$(printf '%s' "$json" | jq -r '.daily_total_seconds // 0')"

  local daily_label=""
  if [ "$daily_total_seconds" -gt 0 ]; then
    daily_label=" • Today: $(seconds_to_short "$daily_total_seconds")"
  fi

  local escaped_mode="$(escape_markup "${mode:-Planned session}")"
  local escaped_daily_label="$(escape_markup "$daily_label")"

  if [ -z "$duration_minutes" ] || [ "$duration_minutes" = "null" ]; then
    printf '<span weight="600">%s</span>%s&#10;%s elapsed\n' \
      "$escaped_mode" \
      "$escaped_daily_label" \
      "$(seconds_to_short "$elapsed_seconds")"
    return 0
  fi

  local bar=""
  local pct_label=""
  if [ "$per_session_seconds" -gt 0 ]; then
    bar="$(progress_bar "$current_session_elapsed_seconds" "$per_session_seconds")"
    local pct=$((current_session_elapsed_seconds * 100 / per_session_seconds))
    pct_label=" ${pct}%"
  fi

  local finish_label=""
  if [ -n "$estimated_finish_at" ] && [ "$estimated_finish_at" != "null" ]; then
    finish_label=" • Finish at $(format_time "$estimated_finish_at")"
  fi

  if [ "$target_reached" = "true" ]; then
    printf '<span weight="600">%s</span> • complete%s&#10;%s\n' \
      "$escaped_mode" \
      "$escaped_daily_label" \
      "$(plan_summary "$duration_minutes" "${planned_sessions:-1}")"
    return 0
  fi

  if [ -n "$planned_sessions" ] && [ -n "$current_session" ] && [ -n "$remaining_total_seconds" ] && [ "$remaining_total_seconds" != "null" ]; then
    printf '<span weight="600">%s</span> • session %s/%s%s&#10;<span size="small">%s%s • %s left • %s%s</span>\n' \
      "$escaped_mode" \
      "$current_session" \
      "$planned_sessions" \
      "$escaped_daily_label" \
      "$bar" \
      "$pct_label" \
      "$(seconds_to_short "$remaining_total_seconds")" \
      "$(plan_summary "$duration_minutes" "$planned_sessions")" \
      "$(escape_markup "$finish_label")"
    return 0
  fi

  printf '<span weight="600">%s</span>%s&#10;<span size="small">%s%s • %sm target • %s elapsed%s</span>\n' \
    "$escaped_mode" \
    "$escaped_daily_label" \
    "$bar" \
    "$pct_label" \
    "$duration_minutes" \
    "$(seconds_to_short "$elapsed_seconds")" \
    "$(escape_markup "$finish_label")"
}

show_plan_breakdown() {
  local json="$1"
  local duration_minutes="$(printf '%s' "$json" | jq -r '.duration_minutes // empty')"
  local planned_sessions="$(printf '%s' "$json" | jq -r '.planned_sessions // empty')"
  local current_session="$(printf '%s' "$json" | jq -r '.current_session // 0')"
  
  if [ -z "$duration_minutes" ] || [ -z "$planned_sessions" ] || [ "$planned_sessions" = "null" ]; then
    return 0
  fi

  generate_breakdown_rows() {
    for ((i=1; i<=planned_sessions; i++)); do
      local label="Session $i ($duration_minutes min)"
      local subtitle=""
      local icon="appointment-symbolic"
      
      if [ "$i" -lt "$current_session" ]; then
        subtitle="Completed"
        icon="emblem-ok-symbolic"
      elif [ "$i" -eq "$current_session" ]; then
        if [ "$(printf '%s' "$json" | jq -r '.target_reached')" = "true" ]; then
          subtitle="Completed"
          icon="emblem-ok-symbolic"
        else
          subtitle="In Progress"
          icon="appointment-soon-symbolic"
        fi
      else
        subtitle="Pending"
      fi
      
      emit_row "session:$i" "$(row_markup "$label" "$subtitle")" "$icon"
    done
    emit_row "back" "$(row_markup "Back")" "go-previous-symbolic"
  }

  while :; do
    local selection="$(generate_breakdown_rows | run_rofi_menu "Session Breakdown")" || return 0
    case "$selection" in
      back|"") return 0 ;;
      *) continue ;;
    esac
  done
}

generate_duration_rows() {
  emit_row "duration:25" "$(row_markup "25-minute block" "Quick focus")" "appointment-soon-symbolic"
  emit_row "duration:50" "$(row_markup "50-minute block" "Deep work default")" "appointment-new-symbolic"
  emit_row "duration:75" "$(row_markup "75-minute block" "Long concentration block")" "alarm-symbolic"
  emit_row "duration:90" "$(row_markup "90-minute block" "Exam or reading sprint")" "alarm-symbolic"
  emit_row "back" "$(row_markup "Back")" "go-previous-symbolic"
  emit_row "close" "$(row_markup "Close")" "window-close-symbolic"
}

generate_session_count_rows() {
  local duration_minutes="$1"
  emit_row "sessions:1" "$(row_markup "1 session" "$(plan_summary "$duration_minutes" 1)")" "view-list-symbolic"
  emit_row "sessions:2" "$(row_markup "2 sessions" "$(plan_summary "$duration_minutes" 2)")" "view-list-symbolic"
  emit_row "sessions:3" "$(row_markup "3 sessions" "$(plan_summary "$duration_minutes" 3)")" "view-list-symbolic"
  emit_row "sessions:4" "$(row_markup "4 sessions" "$(plan_summary "$duration_minutes" 4)")" "view-list-symbolic"
  emit_row "back" "$(row_markup "Back")" "go-previous-symbolic"
  emit_row "close" "$(row_markup "Close")" "window-close-symbolic"
}

choose_duration() {
  generate_duration_rows | run_rofi_menu
}

choose_session_count() {
  local duration_minutes="$1"
  generate_session_count_rows "$duration_minutes" | run_rofi_menu
}

start_planned_session() {
  local duration_minutes="$1"
  local session_count="$2"
  local mode="${3:-Planned session}"
  "$TIMER_BIN" start --duration-minutes "$duration_minutes" --session-count "$session_count" --mode "$mode" >/dev/null 2>&1
}

start_open_ended_session() {
  local mode="${1:-Open-ended session}"
  "$TIMER_BIN" start --mode "$mode" >/dev/null 2>&1
}

start_guided_plan() {
  local duration_selection=""
  local duration_minutes=""
  local session_selection=""
  local session_count=""

  while :; do
    duration_selection="$(choose_duration)" || return 0
    case "$duration_selection" in
      duration:*)
        duration_minutes="${duration_selection#duration:}"
        ;;
      back|close|"")
        return 0
        ;;
      *)
        return 0
        ;;
    esac

    while :; do
      session_selection="$(choose_session_count "$duration_minutes")" || return 0
      case "$session_selection" in
        sessions:*)
          session_count="${session_selection#sessions:}"
          start_planned_session "$duration_minutes" "$session_count" "Custom plan"
          return 0
          ;;
        back)
          break
          ;;
        close|"")
          return 0
          ;;
        *)
          return 0
          ;;
      esac
    done
  done
}

while :; do
  status_json="$("$TIMER_BIN" status --format json)"
  active="$(printf '%s' "$status_json" | jq -r '.active')"
  started_at="$(printf '%s' "$status_json" | jq -r '.started_at // empty')"
  elapsed_seconds="$(printf '%s' "$status_json" | jq -r '.elapsed_seconds // 0')"
  elapsed_label="$("$TIMER_BIN" status | sed 's/^active //; s/^inactive$/No active study session/')"

  generate_rows() {
    if [ "$active" = "true" ]; then
      emit_row "stop" "$(row_markup "Stop study session" "$elapsed_label")" "media-playback-stop-symbolic"
      
      local planned_sessions="$(printf '%s' "$status_json" | jq -r '.planned_sessions // empty')"
      if [ -n "$planned_sessions" ] && [ "$planned_sessions" != "null" ]; then
        emit_row "breakdown" "$(row_markup "View plan breakdown" "See per-session progress")" "view-list-symbolic"
      fi
    else
      emit_row "start:preset:25:1" "$(row_markup "Quick start" "$(plan_summary 25 1)")" "media-playback-start-symbolic"
      emit_row "start:preset:25:4" "$(row_markup "Pomodoro set" "$(plan_summary 25 4)")" "media-playback-start-symbolic"
      emit_row "start:preset:50:2" "$(row_markup "Deep work set" "$(plan_summary 50 2)")" "media-playback-start-symbolic"
      emit_row "start:preset:90:1" "$(row_markup "Long block" "$(plan_summary 90 1)")" "media-playback-start-symbolic"
      emit_row "start:guided" "$(row_markup "Custom study plan" "Choose duration and session count")" "preferences-system-time-symbolic"
      emit_row "start:open" "$(row_markup "Open-ended session" "Classic study timer")" "media-record-symbolic"
    fi
    emit_row "screen-time" "$(row_markup "Open screen time" "Dashboard and study totals")" "view-calendar-symbolic"
    emit_row "close" "$(row_markup "Close")" "window-close-symbolic"
  }

  menu_prompt="Study Timer"
  menu_message=""
  if [ "$active" = "true" ]; then
    menu_prompt="ACTIVE SESSION"
    menu_message="$(active_plan_summary "$status_json")"
  else
    menu_message="Select a study plan to begin."
  fi

  selection="$(
    generate_rows \
      | run_rofi_menu "$menu_prompt" "$menu_message"
  )" || exit 0

  case "$selection" in
    start:preset:*)
      duration_minutes="$(printf '%s' "$selection" | cut -d: -f3)"
      session_count="$(printf '%s' "$selection" | cut -d: -f4)"
      case "$selection" in
        "start:preset:25:1") mode="Quick start" ;;
        "start:preset:25:4") mode="Pomodoro set" ;;
        "start:preset:50:2") mode="Deep work set" ;;
        "start:preset:90:1") mode="Long block" ;;
        *) mode="Preset plan" ;;
      esac
      if confirm_plan "CONFIRM PLAN" "$(plan_summary "$duration_minutes" "$session_count")"; then
        start_planned_session "$duration_minutes" "$session_count" "$mode"
      fi
      ;;
    start:guided)
      start_guided_plan
      ;;
    start:open)
      if confirm_plan "CONFIRM PLAN" "Open-ended session (no time limit)"; then
        start_open_ended_session
      fi
      ;;
    stop)
      "$TIMER_BIN" stop >/dev/null 2>&1
      ;;
    breakdown)
      show_plan_breakdown "$status_json"
      ;;
    screen-time)
      setsid -f "$SCREEN_TIME_BIN" >/dev/null 2>&1 || true
      exit 0
      ;;
    close|"")
      exit 0
      ;;
  esac
done
