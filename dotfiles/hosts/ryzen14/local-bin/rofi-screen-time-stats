#!/usr/bin/env bash
set -euo pipefail

resolve_screen_time_lib_dir() {
  local script_dir
  local candidate=""
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

  for candidate in \
    "${SCREEN_TIME_LIB_DIR:-}" \
    "${SCREEN_TIME_LIB_HOME:-${HOME}/.local/lib/rofi-screen-time}/lib" \
    "$script_dir/../rofi-screen-time/lib" \
    "/etc/nixos/dotfiles/hosts/ryzen14/rofi-screen-time/lib"
  do
    [ -n "$candidate" ] || continue
    if [ -r "$candidate/common.sh" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'rofi-screen-time-stats: unable to locate rofi-screen-time libs\n' >&2
  return 1
}

SCREEN_TIME_LIB_DIR="$(resolve_screen_time_lib_dir)"
# shellcheck source=/dev/null
. "$SCREEN_TIME_LIB_DIR/common.sh"
# shellcheck source=/dev/null
. "$SCREEN_TIME_LIB_DIR/category-map.sh"
# shellcheck source=/dev/null
. "$SCREEN_TIME_LIB_DIR/metrics.sh"
# shellcheck source=/dev/null
. "$SCREEN_TIME_LIB_DIR/scores.sh"
# shellcheck source=/dev/null
. "$SCREEN_TIME_LIB_DIR/insights.sh"
# shellcheck source=/dev/null
. "$SCREEN_TIME_LIB_DIR/views.sh"

VIEW="summary"
FORMAT="json"
TARGET_DATE="$(date +%F)"
APP_FILTER=""
THEME_FILE=""
ROWS_FILE=""

usage() {
  cat <<'EOF'
Usage: rofi-screen-time-stats [--date YYYY-MM-DD] [--view summary|activity|health|timer] [--app APP_CLASS] [--format json|theme|rows|files] [--theme-file PATH --rows-file PATH]
EOF
}

render_files() {
  local payload_json="$1"
  local theme_tmp=""
  local rows_tmp=""

  theme_tmp="$(mktemp "${THEME_FILE}.XXXXXX")"
  rows_tmp="$(mktemp "${ROWS_FILE}.XXXXXX")"
  render_theme "$payload_json" >"$theme_tmp"
  render_rows "$payload_json" >"$rows_tmp"
  mv "$theme_tmp" "$THEME_FILE"
  mv "$rows_tmp" "$ROWS_FILE"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --date)
      TARGET_DATE="${2:-}"
      shift 2
      ;;
    --view)
      VIEW="${2:-}"
      shift 2
      ;;
    --format)
      FORMAT="${2:-}"
      shift 2
      ;;
    --theme-file)
      THEME_FILE="${2:-}"
      shift 2
      ;;
    --rows-file)
      ROWS_FILE="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

TARGET_DATE="$(date -d "$TARGET_DATE" +%F 2>/dev/null || date +%F)"
if ! VIEW="$(resolve_screen_time_view "$VIEW")"; then
  printf 'rofi-screen-time-stats: invalid view %s\n' "$VIEW" >&2
  exit 2
fi

case "$FORMAT" in
  json|theme|rows|files) ;;
  *)
    printf 'rofi-screen-time-stats: invalid format %s\n' "$FORMAT" >&2
    exit 2
    ;;
esac

if [ "$FORMAT" = "files" ] && { [ -z "$THEME_FILE" ] || [ -z "$ROWS_FILE" ]; }; then
  printf 'rofi-screen-time-stats: --theme-file and --rows-file are required for format files\n' >&2
  exit 2
fi

mkdir -p "$SCREEN_TIME_CACHE_HOME"

CATEGORY_MAP_JSON="$(load_category_map_json)"
BUNDLE_JSON="$(build_data_bundle_json "$TARGET_DATE" "$CATEGORY_MAP_JSON")"
METRICS_JSON="$(build_metrics_context "$BUNDLE_JSON")"
SCORED_JSON="$(build_scored_context "$METRICS_JSON")"
CONTEXT_JSON="$(build_insighted_context "$SCORED_JSON")"
PAYLOAD_JSON="$(build_view_payload "$VIEW" "$CONTEXT_JSON")"

case "$FORMAT" in
  json)
    printf '%s\n' "$PAYLOAD_JSON"
    ;;
  theme)
    render_theme "$PAYLOAD_JSON"
    ;;
  rows)
    render_rows "$PAYLOAD_JSON"
    ;;
  files)
    render_files "$PAYLOAD_JSON"
    ;;
esac
