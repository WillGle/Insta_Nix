#!/usr/bin/env bash
set -euo pipefail

export PATH="/run/current-system/sw/bin:/etc/profiles/per-user/${USER:-$(id -un)}/bin:${HOME}/.nix-profile/bin:${PATH}"

SCREEN_TIME_HOME="${SCREEN_TIME_HOME:-${HOME}/.local/share/rofi-screen-time}"
SCREEN_TIME_CACHE_HOME="${SCREEN_TIME_CACHE_HOME:-${HOME}/.cache/rofi-screen-time}"
THEME_STATIC_ENV="${HOME}/.config/theme/static.env"

if [ -r "$THEME_STATIC_ENV" ]; then
  # shellcheck disable=SC1090
  . "$THEME_STATIC_ENV"
fi

BASE_COLOR="${THEME_STATIC_BASE:-#11140f}"
MANTLE_COLOR="${THEME_STATIC_MANTLE:-#1d211b}"
TEXT_COLOR="${THEME_STATIC_TEXT:-#e1e4da}"
SUBTEXT_COLOR="${THEME_STATIC_SUBTEXT:-#c3c8bc}"
ACCENT_COLOR="${THEME_STATIC_ACCENT:-#a7d293}"
SUCCESS_COLOR="${THEME_STATIC_SUCCESS:-#bccbb1}"
WARNING_COLOR="${THEME_STATIC_WARNING:-#d29922}"
ERROR_COLOR="${THEME_STATIC_ERROR:-#f85149}"
PURPLE_COLOR="${THEME_STATIC_PURPLE:-#a0cfd1}"
CYAN_COLOR="${THEME_STATIC_CYAN:-#bccbb1}"

CACHE_FILE="${SCREEN_TIME_CACHE_HOME}/desktop-cache.tsv"
VIEW="day"
FORMAT="json"
TARGET_DATE="$(date +%F)"
APP_FILTER=""

usage() {
  cat <<'EOF'
Usage: rofi-screen-time-stats [--date YYYY-MM-DD] [--view day|week|app] [--app APP_CLASS] [--format json|theme|rows]
EOF
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

normalize_class() {
  local value
  value="$(trim "${1,,}")"
  value="${value%.exe}"
  value="${value%-updater}"
  value="${value%_updater}"
  value="${value% updater}"
  printf '%s\n' "$value"
}

humanize_class() {
  local value="${1//[_-]/ }"
  local out=""
  local word=""
  for word in $value; do
    out+="${word^} "
  done
  printf '%s\n' "${out%" "}"
}

escape_markup() {
  local value="${1//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  printf '%s\n' "$value"
}

rasi_quote() {
  jq -Rn --arg value "$1" '$value'
}

seconds_to_compact() {
  local total="${1:-0}"
  local hours=$((total / 3600))
  local minutes=$(((total % 3600) / 60))

  if [ "$total" -gt 0 ] && [ "$hours" -eq 0 ] && [ "$minutes" -eq 0 ]; then
    printf '<1m\n'
    return 0
  fi
  if [ "$hours" -gt 0 ]; then
    printf '%dh %02dm\n' "$hours" "$minutes"
    return 0
  fi
  printf '%dm\n' "$minutes"
}

seconds_to_short() {
  local total="${1:-0}"
  local hours=$((total / 3600))
  local minutes=$(((total % 3600) / 60))

  if [ "$total" -gt 0 ] && [ "$hours" -eq 0 ] && [ "$minutes" -eq 0 ]; then
    printf '<1m\n'
    return 0
  fi
  if [ "$hours" -gt 0 ] && [ "$minutes" -gt 0 ]; then
    printf '%dh %dm\n' "$hours" "$minutes"
    return 0
  fi
  if [ "$hours" -gt 0 ]; then
    printf '%dh\n' "$hours"
    return 0
  fi
  printf '%dm\n' "$minutes"
}

percent_label() {
  local numerator="$1"
  local denominator="$2"
  if [ "$denominator" -le 0 ]; then
    printf '0%%\n'
    return 0
  fi
  printf '%d%%\n' $(( (numerator * 100) / denominator ))
}

date_title() {
  local target="$1"
  local today
  local yesterday
  today="$(date +%F)"
  yesterday="$(date -d "$today -1 day" +%F)"

  if [ "$target" = "$today" ]; then
    printf 'Today\n'
  elif [ "$target" = "$yesterday" ]; then
    printf 'Yesterday\n'
  else
    date -d "$target" '+%a %d %b'
  fi
}

day_file() {
  printf '%s/days/%s.json\n' "$SCREEN_TIME_HOME" "$1"
}

build_desktop_cache() {
  if [ -s "$CACHE_FILE" ]; then
    return 0
  fi
  mkdir -p "$SCREEN_TIME_CACHE_HOME"

  local tmp
  local xdg_data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
  local xdg_data_dirs="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
  local data_dir=""
  local search_dirs=("$xdg_data_home/applications")
  local dir=""
  local desktop=""
  local name=""
  local icon=""
  local wmclass=""
  local key=""
  tmp="$(mktemp)"

  for data_dir in ${xdg_data_dirs//:/ }; do
    search_dirs+=("$data_dir/applications")
  done
  search_dirs+=(
    "/var/lib/flatpak/exports/share/applications"
    "/var/lib/snapd/desktop/applications"
  )

  {
    for dir in "${search_dirs[@]}"; do
      [ -d "$dir" ] || continue
      while IFS= read -r -d '' desktop; do
        name=""
        icon=""
        wmclass=""
        while IFS= read -r line; do
          case "$line" in
            Name=*)
              [ -n "$name" ] || name="${line#Name=}"
              ;;
            Icon=*)
              [ -n "$icon" ] || icon="${line#Icon=}"
              ;;
            StartupWMClass=*)
              [ -n "$wmclass" ] || wmclass="${line#StartupWMClass=}"
              ;;
          esac
        done <"$desktop"

        if [ -z "$name" ]; then
          continue
        fi
        key="$(normalize_class "$(basename "$desktop" .desktop)")"
        if [ -n "$key" ]; then
          printf '%s\t%s\t%s\n' "$key" "$name" "$icon"
        fi
        if [ -n "$wmclass" ]; then
          key="$(normalize_class "$wmclass")"
          if [ -n "$key" ]; then
            printf '%s\t%s\t%s\n' "$key" "$name" "$icon"
          fi
        fi
      done < <(find "$dir" -maxdepth 1 -type f -name '*.desktop' -print0 2>/dev/null)
    done
  } | awk -F '\t' '!seen[$1]++' >"$tmp"

  mv "$tmp" "$CACHE_FILE"
}

resolve_app_meta() {
  local app_key="$1"
  local name=""
  local icon=""

  build_desktop_cache
  if [ -s "$CACHE_FILE" ]; then
    name="$(awk -F '\t' -v key="$app_key" '$1 == key { print $2; exit }' "$CACHE_FILE")"
    icon="$(awk -F '\t' -v key="$app_key" '$1 == key { print $3; exit }' "$CACHE_FILE")"
  fi

  if [ -z "$name" ]; then
    name="$(humanize_class "$app_key")"
  fi
  printf '%s\t%s\n' "$name" "$icon"
}

day_total() {
  local target="$1"
  local app_key="${2:-}"
  local file
  file="$(day_file "$target")"

  [ -f "$file" ] || {
    printf '0\n'
    return 0
  }

  if [ -n "$app_key" ]; then
    jq -r --arg app "$app_key" '(.apps[$app].seconds // 0)' "$file"
  else
    jq -r '(.total_seconds // 0)' "$file"
  fi
}

day_slots_json() {
  local target="$1"
  local app_key="${2:-}"
  local file
  file="$(day_file "$target")"

  [ -f "$file" ] || {
    jq -nc '[range(0; 48) | 0]'
    return 0
  }

  if [ -n "$app_key" ]; then
    jq -c --arg app "$app_key" '(.apps[$app].slots_30m // ([range(0; 48)] | map(0)))' "$file"
  else
    jq -c '(.slots_30m // ([range(0; 48)] | map(0)))' "$file"
  fi
}

day_apps_json() {
  local target="$1"
  local file
  file="$(day_file "$target")"

  [ -f "$file" ] || {
    printf '[]\n'
    return 0
  }

  jq -c '
    (.total_seconds // 0) as $total
    | (.apps // {})
    | to_entries
    | map(
        .value
        + {
            key: .key,
            percent: (if $total > 0 then ((.value.seconds // 0) * 100 / $total) else 0 end)
          }
      )
    | sort_by(-.seconds, .name)
  ' "$file"
}

week_apps_json() {
  local week_start="$1"
  local week_end="$2"
  local files=()
  local cursor="$week_start"
  local file=""

  while :; do
    file="$(day_file "$cursor")"
    if [ -f "$file" ]; then
      files+=("$file")
    fi
    if [ "$cursor" = "$week_end" ]; then
      break
    fi
    cursor="$(date -d "$cursor +1 day" +%F)"
  done

  [ "${#files[@]}" -gt 0 ] || {
    printf '[]\n'
    return 0
  }

  jq -sc '
    reduce .[] as $day ({};
      reduce (($day.apps // {}) | to_entries[]) as $entry (.;
        .[$entry.key] = (
          (.[$entry.key] // {
            key: $entry.key,
            class: ($entry.value.class // $entry.key),
            name: ($entry.value.name // $entry.key),
            icon: ($entry.value.icon // ""),
            seconds: 0
          })
          | .seconds += ($entry.value.seconds // 0)
        )
      )
    )
    | to_entries
    | map(.value)
    | sort_by(-.seconds, .name)
  ' "${files[@]}"
}

sparkline_from_json() {
  local values_json="$1"
  local highlight_index="${2:-}"
  local length
  local max
  local index=0
  local value=0
  local glyph=""
  local out=""
  local chars=(▁ ▂ ▃ ▄ ▅ ▆ ▇ █)

  length="$(printf '%s' "$values_json" | jq 'length')"
  max="$(printf '%s' "$values_json" | jq 'max // 0')"
  if [ "$length" -le 0 ]; then
    printf '%s\n' ""
    return 0
  fi

  while [ "$index" -lt "$length" ]; do
    value="$(printf '%s' "$values_json" | jq -r ".[$index] // 0")"
    if [ "$max" -le 0 ]; then
      glyph="${chars[0]}"
    else
      glyph="${chars[$((value * 7 / max))]}"
    fi

    if [ -n "$highlight_index" ] && [ "$index" -eq "$highlight_index" ]; then
      out+="<span foreground=\"$ACCENT_COLOR\">$glyph</span>"
    else
      out+="<span foreground=\"$SUCCESS_COLOR\">$glyph</span>"
    fi
    index=$((index + 1))
  done

  printf '%s\n' "$out"
}

render_week_chart() {
  local week_json="$1"
  local values
  local labels
  local highlight_index
  values="$(printf '%s' "$week_json" | jq -c 'map(.total)')"
  labels="$(printf '%s' "$week_json" | jq -r 'map(.day) | join("  ")')"
  highlight_index="$(printf '%s' "$week_json" | jq -r 'to_entries[] | select(.value.is_target) | .key' 2>/dev/null || true)"
  if [ -z "$highlight_index" ]; then
    highlight_index=""
  fi
  printf '%s\n<span foreground="%s" size="small">%s</span>\n' \
    "$(sparkline_from_json "$values" "$highlight_index")" \
    "$SUBTEXT_COLOR" \
    "$labels"
}

render_histogram_chart() {
  local slots_json="$1"
  printf '%s\n<span foreground="%s" size="small">00   06   12   18   23</span>\n' \
    "$(sparkline_from_json "$slots_json")" \
    "$SUBTEXT_COLOR"
}

heatmap_color() {
  local total="$1"
  if [ "$total" -le 0 ]; then
    printf '%s\n' "$MANTLE_COLOR"
  elif [ "$total" -lt 1800 ]; then
    printf '%s\n' "$SUCCESS_COLOR"
  elif [ "$total" -lt 5400 ]; then
    printf '%s\n' "$ACCENT_COLOR"
  elif [ "$total" -lt 14400 ]; then
    printf '%s\n' "$CYAN_COLOR"
  else
    printf '%s\n' "$TEXT_COLOR"
  fi
}

render_month_heatmap() {
  local month_json="$1"
  local target="$2"
  local length
  local index=0
  local cell_date=""
  local cell_total=0
  local line=""
  local output='<span foreground="'"$SUBTEXT_COLOR"'" size="small">Mo Tu We Th Fr Sa Su</span>'
  local day_text=""
  local color=""

  length="$(printf '%s' "$month_json" | jq 'length')"
  while [ "$index" -lt "$length" ]; do
    if [ $((index % 7)) -eq 0 ]; then
      line=""
    fi

    cell_date="$(printf '%s' "$month_json" | jq -r ".[$index].date")"
    cell_total="$(printf '%s' "$month_json" | jq -r ".[$index].total")"

    if [ "$cell_date" = "" ]; then
      line+='   '
    else
      color="$(heatmap_color "$cell_total")"
      day_text="$(date -d "$cell_date" +%d)"
      if [ "$cell_date" = "$target" ]; then
        line+="<span background=\"$TEXT_COLOR\" foreground=\"$BASE_COLOR\">$day_text</span> "
      else
        line+="<span background=\"$color\" foreground=\"$BASE_COLOR\">$day_text</span> "
      fi
    fi

    if [ $((index % 7)) -eq 6 ] || [ "$index" -eq $((length - 1)) ]; then
      output+=$'\n'
      output+="$line"
    fi
    index=$((index + 1))
  done

  printf '%s\n' "$output"
}

action_row_markup() {
  local label="$1"
  local hint="${2:-}"
  if [ -n "$hint" ]; then
    printf '<span weight="600">%s</span>  <span foreground="%s" size="small">%s</span>' \
      "$(escape_markup "$label")" \
      "$SUBTEXT_COLOR" \
      "$(escape_markup "$hint")"
  else
    printf '<span weight="600">%s</span>' "$(escape_markup "$label")"
  fi
}

app_row_markup() {
  local name="$1"
  local seconds="$2"
  local max_seconds="$3"
  local percent="$4"
  local filled=0
  local total_blocks=18
  local bar=""
  local empty=""
  local i=0

  if [ "$max_seconds" -gt 0 ]; then
    filled=$((seconds * total_blocks / max_seconds))
  fi
  if [ "$filled" -le 0 ]; then
    filled=1
  fi
  if [ "$seconds" -le 0 ]; then
    filled=0
  fi

  while [ "$i" -lt "$filled" ]; do
    bar+="█"
    i=$((i + 1))
  done
  while [ "$i" -lt "$total_blocks" ]; do
    empty+="░"
    i=$((i + 1))
  done

  printf '<span weight="600">%s</span>  <span foreground="%s">%s</span>  <span foreground="%s" size="small">%s</span>  <span foreground="%s">%s</span><span foreground="%s">%s</span>' \
    "$(escape_markup "$name")" \
    "$TEXT_COLOR" \
    "$(seconds_to_short "$seconds")" \
    "$SUBTEXT_COLOR" \
    "$percent" \
    "$ACCENT_COLOR" \
    "$bar" \
    "$MANTLE_COLOR" \
    "$empty"
}

emit_row() {
  local token="$1"
  local display="$2"
  local icon="${3:-}"
  printf '%s' "$token"
  printf '\0display\x1f%s' "$display"
  if [ -n "$icon" ]; then
    printf '\x1ficon\x1f%s' "$icon"
  fi
  printf '\n'
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --date)
      TARGET_DATE="${2:-}"
      shift 2
      ;;
    --view)
      VIEW="${2:-}"
      shift 2
      ;;
    --app)
      APP_FILTER="$(normalize_class "${2:-}")"
      shift 2
      ;;
    --format)
      FORMAT="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

TARGET_DATE="$(date -d "$TARGET_DATE" +%F 2>/dev/null || date +%F)"
case "$VIEW" in
  day|week|app) ;;
  *)
    printf 'rofi-screen-time-stats: invalid view %s\n' "$VIEW" >&2
    exit 2
    ;;
esac
case "$FORMAT" in
  json|theme|rows) ;;
  *)
    printf 'rofi-screen-time-stats: invalid format %s\n' "$FORMAT" >&2
    exit 2
    ;;
esac

mkdir -p "$SCREEN_TIME_CACHE_HOME"

TODAY="$(date +%F)"
YESTERDAY="$(date -d "$TARGET_DATE -1 day" +%F)"
SELECTED_TOTAL="$(day_total "$TARGET_DATE" "$APP_FILTER")"
YESTERDAY_TOTAL="$(day_total "$YESTERDAY" "$APP_FILTER")"
DELTA_SECONDS=$((SELECTED_TOTAL - YESTERDAY_TOTAL))

WEEKDAY_INDEX="$(date -d "$TARGET_DATE" +%u)"
WEEK_START="$(date -d "$TARGET_DATE -$((10#$WEEKDAY_INDEX - 1)) days" +%F)"
WEEK_END="$(date -d "$WEEK_START +6 days" +%F)"
CURRENT_WEEKDAY_INDEX="$(date +%u)"
CURRENT_WEEK_START="$(date -d "$TODAY -$((10#$CURRENT_WEEKDAY_INDEX - 1)) days" +%F)"

WEEK_ROWS=()
MONTH_ROWS=()
WEEK_TOTAL=0
ACTIVE_DAYS=0
cursor="$WEEK_START"
while :; do
  total="$(day_total "$cursor" "$APP_FILTER")"
  WEEK_TOTAL=$((WEEK_TOTAL + total))
  if [ "$total" -gt 0 ]; then
    ACTIVE_DAYS=$((ACTIVE_DAYS + 1))
  fi
  is_target=false
  if [ "$cursor" = "$TARGET_DATE" ]; then
    is_target=true
  fi
  WEEK_ROWS+=("$(jq -nc \
    --arg date "$cursor" \
    --arg day "$(date -d "$cursor" +%a | cut -c1-3)" \
    --argjson total "$total" \
    --argjson is_target "$is_target" \
    '{date:$date, day:$day, total:$total, is_target:$is_target}')")
  if [ "$cursor" = "$WEEK_END" ]; then
    break
  fi
  cursor="$(date -d "$cursor +1 day" +%F)"
done
WEEK_JSON="$(printf '%s\n' "${WEEK_ROWS[@]}" | jq -sc '.')"
if [ "$ACTIVE_DAYS" -gt 0 ]; then
  WEEK_AVERAGE=$((WEEK_TOTAL / ACTIVE_DAYS))
else
  WEEK_AVERAGE=0
fi

MONTH_START="$(date -d "$TARGET_DATE" +%Y-%m-01)"
MONTH_NAME="$(date -d "$TARGET_DATE" +%B)"
MONTH_DAYS="$(date -d "$MONTH_START +1 month -1 day" +%d)"
MONTH_FIRST_WEEKDAY="$(date -d "$MONTH_START" +%u)"
blank=1
while [ "$blank" -lt "$MONTH_FIRST_WEEKDAY" ]; do
  MONTH_ROWS+=("$(jq -nc '{date:"", total:-1}')")
  blank=$((blank + 1))
done

day_num=1
while [ "$day_num" -le $((10#$MONTH_DAYS)) ]; do
  month_date="$(date -d "$MONTH_START +$((day_num - 1)) days" +%F)"
  total="$(day_total "$month_date" "$APP_FILTER")"
  MONTH_ROWS+=("$(jq -nc \
    --arg date "$month_date" \
    --argjson total "$total" \
    '{date:$date, total:$total}')")
  day_num=$((day_num + 1))
done
MONTH_JSON="$(printf '%s\n' "${MONTH_ROWS[@]}" | jq -sc '.')"

DAY_APPS_JSON="$(day_apps_json "$TARGET_DATE")"
WEEK_APPS_JSON="$(week_apps_json "$WEEK_START" "$WEEK_END")"
DAY_SLOTS_JSON="$(day_slots_json "$TARGET_DATE" "$APP_FILTER")"
if [ -d "$SCREEN_TIME_HOME/days" ]; then
  FILE_COUNT="$(find "$SCREEN_TIME_HOME/days" -maxdepth 1 -type f -name '*.json' | wc -l | tr -d ' ')"
else
  FILE_COUNT=0
fi
HAS_ANY_DATA=false
if [ "$FILE_COUNT" -gt 0 ]; then
  HAS_ANY_DATA=true
fi

APP_NAME=""
APP_ICON=""
APP_DAY_TOTAL="$SELECTED_TOTAL"
APP_WEEK_TOTAL=0
APP_SHARE="0%"
if [ -n "$APP_FILTER" ]; then
  APP_WEEK_TOTAL="$(printf '%s' "$WEEK_APPS_JSON" | jq -r --arg app "$APP_FILTER" 'map(select(.key == $app))[0].seconds // 0')"
  APP_SHARE="$(percent_label "$APP_DAY_TOTAL" "$(day_total "$TARGET_DATE")")"
  meta="$(resolve_app_meta "$APP_FILTER")"
  APP_NAME="${meta%%$'\t'*}"
  APP_ICON="${meta#*$'\t'}"
fi

DAY_TOP_SECONDS="$(printf '%s' "$DAY_APPS_JSON" | jq -r '.[0].seconds // 0')"
WEEK_TOP_SECONDS="$(printf '%s' "$WEEK_APPS_JSON" | jq -r '.[0].seconds // 0')"
WEEK_TOP_NAME="$(printf '%s' "$WEEK_APPS_JSON" | jq -r '.[0].name // "No data"')"
WEEK_TOP_DURATION="$(printf '%s' "$WEEK_APPS_JSON" | jq -r '.[0].seconds // 0')"

WEEK_RANGE_LABEL="$(date -d "$WEEK_START" '+%b %d') - $(date -d "$WEEK_END" '+%b %d')"
DAY_TITLE="$(date_title "$TARGET_DATE")"
DELTA_ARROW="→"
if [ "$DELTA_SECONDS" -gt 0 ]; then
  DELTA_ARROW="↑"
elif [ "$DELTA_SECONDS" -lt 0 ]; then
  DELTA_ARROW="↓"
fi
DELTA_ABS="${DELTA_SECONDS#-}"

TITLE_TEXT="$DAY_TITLE"
CARD1_LABEL=""
CARD1_VALUE=""
CARD1_SUB=""
CARD2_LABEL=""
CARD2_VALUE=""
CARD2_SUB=""
CARD3_LABEL=""
CARD3_VALUE=""
CARD3_SUB=""
CHART_A_TITLE=""
CHART_A_BODY=""
CHART_B_TITLE=""
CHART_B_BODY=""
NOTE_TEXT=""

case "$VIEW" in
  day)
    CARD1_LABEL="Daily average"
    CARD1_VALUE="$(seconds_to_compact "$WEEK_AVERAGE")"
    CARD1_SUB="$WEEK_RANGE_LABEL"
    CARD2_LABEL="Tracked today"
    CARD2_VALUE="$(seconds_to_compact "$SELECTED_TOTAL")"
    CARD2_SUB="$(date -d "$TARGET_DATE" '+%A, %d %b')"
    CARD3_LABEL="Vs yesterday"
    CARD3_VALUE="$DELTA_ARROW $(seconds_to_compact "$DELTA_ABS")"
    CARD3_SUB="Yesterday $(seconds_to_short "$YESTERDAY_TOTAL")"
    CHART_A_TITLE="7-day trend"
    CHART_A_BODY="$(render_week_chart "$WEEK_JSON")"
    CHART_B_TITLE="$MONTH_NAME"
    CHART_B_BODY="$(render_month_heatmap "$MONTH_JSON" "$TARGET_DATE")"
    if [ "$HAS_ANY_DATA" = false ]; then
      NOTE_TEXT="Tracking starts with your Hyprland session. Use the machine normally for a few minutes, then refresh."
    else
      NOTE_TEXT="Use Enter on an app to inspect its half-hour breakdown."
    fi
    ;;
  week)
    TITLE_TEXT="Week of $(date -d "$WEEK_START" '+%d %b')"
    CARD1_LABEL="Week total"
    CARD1_VALUE="$(seconds_to_compact "$WEEK_TOTAL")"
    CARD1_SUB="$WEEK_RANGE_LABEL"
    CARD2_LABEL="Average / active day"
    CARD2_VALUE="$(seconds_to_compact "$WEEK_AVERAGE")"
    CARD2_SUB="$ACTIVE_DAYS active days"
    CARD3_LABEL="Top app"
    CARD3_VALUE="$(escape_markup "$WEEK_TOP_NAME")"
    CARD3_SUB="$(seconds_to_short "$WEEK_TOP_DURATION")"
    CHART_A_TITLE="7-day trend"
    CHART_A_BODY="$(render_week_chart "$WEEK_JSON")"
    CHART_B_TITLE="$MONTH_NAME"
    CHART_B_BODY="$(render_month_heatmap "$MONTH_JSON" "$TARGET_DATE")"
    NOTE_TEXT="Select an app to jump into its daily rhythm for $(date -d "$TARGET_DATE" '+%d %b')."
    ;;
  app)
    if [ -z "$APP_FILTER" ]; then
      APP_FILTER="$(printf '%s' "$DAY_APPS_JSON" | jq -r '.[0].key // empty')"
      if [ -n "$APP_FILTER" ]; then
        meta="$(resolve_app_meta "$APP_FILTER")"
        APP_NAME="${meta%%$'\t'*}"
        APP_ICON="${meta#*$'\t'}"
        APP_DAY_TOTAL="$(day_total "$TARGET_DATE" "$APP_FILTER")"
        APP_WEEK_TOTAL="$(printf '%s' "$WEEK_APPS_JSON" | jq -r --arg app "$APP_FILTER" 'map(select(.key == $app))[0].seconds // 0')"
        APP_SHARE="$(percent_label "$APP_DAY_TOTAL" "$(day_total "$TARGET_DATE")")"
      fi
    fi
    if [ -z "$APP_NAME" ]; then
      APP_NAME="App focus"
    fi
    TITLE_TEXT="$(escape_markup "$APP_NAME")"
    CARD1_LABEL="Selected day"
    CARD1_VALUE="$(seconds_to_compact "$APP_DAY_TOTAL")"
    CARD1_SUB="$(date -d "$TARGET_DATE" '+%A, %d %b')"
    CARD2_LABEL="Week total"
    CARD2_VALUE="$(seconds_to_compact "$APP_WEEK_TOTAL")"
    CARD2_SUB="$WEEK_RANGE_LABEL"
    CARD3_LABEL="Share of day"
    CARD3_VALUE="$APP_SHARE"
    CARD3_SUB="of tracked focus time"
    CHART_A_TITLE="Daily usage by half-hour"
    CHART_A_BODY="$(render_histogram_chart "$(day_slots_json "$TARGET_DATE" "$APP_FILTER")")"
    CHART_B_TITLE="7-day app trend"
    app_week_values="$(printf '%s' "$WEEK_JSON" | jq -c 'map(.date)')"
    APP_WEEK_POINTS=()
    idx=0
    while [ "$idx" -lt 7 ]; do
      d="$(printf '%s' "$WEEK_JSON" | jq -r ".[$idx].date")"
      APP_WEEK_POINTS+=("$(day_total "$d" "$APP_FILTER")")
      idx=$((idx + 1))
    done
    APP_WEEK_VALUES_JSON="$(printf '%s\n' "${APP_WEEK_POINTS[@]}" | jq -Rsc 'split("\n") | map(select(length > 0) | tonumber)')"
    CHART_B_BODY="$(printf '%s\n<span foreground="%s" size="small">%s</span>\n' \
      "$(sparkline_from_json "$APP_WEEK_VALUES_JSON")" \
      "$SUBTEXT_COLOR" \
      "$(printf '%s' "$WEEK_JSON" | jq -r 'map(.day) | join("  ")')")"
    NOTE_TEXT="This view excludes rofi, desktop, idle, and lock time."
    ;;
esac

build_json_payload() {
  jq -n \
    --arg view "$VIEW" \
    --arg target_date "$TARGET_DATE" \
    --arg title "$TITLE_TEXT" \
    --arg card1_label "$CARD1_LABEL" \
    --arg card1_value "$CARD1_VALUE" \
    --arg card1_sub "$CARD1_SUB" \
    --arg card2_label "$CARD2_LABEL" \
    --arg card2_value "$CARD2_VALUE" \
    --arg card2_sub "$CARD2_SUB" \
    --arg card3_label "$CARD3_LABEL" \
    --arg card3_value "$CARD3_VALUE" \
    --arg card3_sub "$CARD3_SUB" \
    --arg chart_a_title "$CHART_A_TITLE" \
    --arg chart_a_body "$CHART_A_BODY" \
    --arg chart_b_title "$CHART_B_TITLE" \
    --arg chart_b_body "$CHART_B_BODY" \
    --arg note "$NOTE_TEXT" \
    --arg app "$APP_FILTER" \
    --arg app_name "$APP_NAME" \
    --arg app_icon "$APP_ICON" \
    --argjson day_apps "$DAY_APPS_JSON" \
    --argjson week_apps "$WEEK_APPS_JSON" \
    --argjson week "$WEEK_JSON" \
    --argjson month "$MONTH_JSON" \
    --argjson total "$SELECTED_TOTAL" \
    --argjson week_total "$WEEK_TOTAL" \
    --argjson yesterday "$YESTERDAY_TOTAL" \
    --argjson delta "$DELTA_SECONDS" \
    --argjson has_any_data "$HAS_ANY_DATA" \
    '{
      view: $view,
      target_date: $target_date,
      app: $app,
      app_name: $app_name,
      app_icon: $app_icon,
      title: $title,
      cards: [
        {label: $card1_label, value: $card1_value, sub: $card1_sub},
        {label: $card2_label, value: $card2_value, sub: $card2_sub},
        {label: $card3_label, value: $card3_value, sub: $card3_sub}
      ],
      chart_a: {title: $chart_a_title, body: $chart_a_body},
      chart_b: {title: $chart_b_title, body: $chart_b_body},
      note: $note,
      total: $total,
      week_total: $week_total,
      yesterday: $yesterday,
      delta: $delta,
      has_any_data: $has_any_data,
      day_apps: $day_apps,
      week_apps: $week_apps,
      week: $week,
      month: $month
    }'
}

render_theme() {
  local json="$1"
  cat <<EOF
textbox-title { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.title')"); }
textbox-card-1-label { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[0].label')"); }
textbox-card-1-value { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[0].value')"); }
textbox-card-1-sub { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[0].sub')"); }
textbox-card-2-label { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[1].label')"); }
textbox-card-2-value { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[1].value')"); }
textbox-card-2-sub { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[1].sub')"); }
textbox-card-3-label { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[2].label')"); }
textbox-card-3-value { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[2].value')"); }
textbox-card-3-sub { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.cards[2].sub')"); }
textbox-chart-a-title { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.chart_a.title')"); }
textbox-chart-a-body { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.chart_a.body')"); }
textbox-chart-b-title { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.chart_b.title')"); }
textbox-chart-b-body { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.chart_b.body')"); }
textbox-note { content: $(rasi_quote "$(printf '%s' "$json" | jq -r '.note')"); }
EOF
}

render_rows() {
  local json="$1"
  local selected_date
  local today
  selected_date="$(printf '%s' "$json" | jq -r '.target_date')"
  today="$(date +%F)"

  case "$VIEW" in
    day)
      emit_row "nav:prev-day:$(date -d "$selected_date -1 day" +%F)" "$(action_row_markup "Previous day" "$(date -d "$selected_date -1 day" '+%a %d %b')")" "go-previous-symbolic"
      if [ "$selected_date" != "$today" ]; then
        emit_row "nav:next-day:$(date -d "$selected_date +1 day" +%F)" "$(action_row_markup "Next day" "$(date -d "$selected_date +1 day" '+%a %d %b')")" "go-next-symbolic"
      fi
      emit_row "view:week:$selected_date" "$(action_row_markup "Week view" "$WEEK_RANGE_LABEL")" "view-calendar-week"
      if [ "$(printf '%s' "$json" | jq -r '.has_any_data')" = "true" ]; then
        printf '%s' "$json" | jq -c '.day_apps[:8][]' | while IFS= read -r app_json; do
          app_key="$(printf '%s' "$app_json" | jq -r '.key')"
          app_name="$(printf '%s' "$app_json" | jq -r '.name')"
          app_icon="$(printf '%s' "$app_json" | jq -r '.icon // empty')"
          app_seconds="$(printf '%s' "$app_json" | jq -r '.seconds // 0')"
          app_percent="$(printf '%s' "$app_json" | jq -r '((.percent // 0) | floor | tostring) + "%"')"
          emit_row "app:$app_key:$selected_date" "$(app_row_markup "$app_name" "$app_seconds" "$DAY_TOP_SECONDS" "$app_percent")" "$app_icon"
        done
      fi
      emit_row "refresh:day:$selected_date" "$(action_row_markup "Refresh")" "view-refresh-symbolic"
      emit_row "close" "$(action_row_markup "Close")" "window-close-symbolic"
      ;;
    week)
      emit_row "nav:prev-week:$(date -d "$selected_date -7 days" +%F)" "$(action_row_markup "Previous week" "$(date -d "$selected_date -7 days" '+%d %b')")" "go-previous-symbolic"
      if [ "$(date -d "$selected_date +7 days" +%F)" \< "$(date -d "$today +1 day" +%F)" ]; then
        emit_row "nav:next-week:$(date -d "$selected_date +7 days" +%F)" "$(action_row_markup "Next week" "$(date -d "$selected_date +7 days" '+%d %b')")" "go-next-symbolic"
      fi
      emit_row "view:day:$selected_date" "$(action_row_markup "Back to day" "$DAY_TITLE")" "go-home-symbolic"
      printf '%s' "$json" | jq -c '.week_apps[:8][]' | while IFS= read -r app_json; do
        app_key="$(printf '%s' "$app_json" | jq -r '.key')"
        app_name="$(printf '%s' "$app_json" | jq -r '.name')"
        app_icon="$(printf '%s' "$app_json" | jq -r '.icon // empty')"
        app_seconds="$(printf '%s' "$app_json" | jq -r '.seconds // 0')"
        app_percent="$(percent_label "$app_seconds" "$WEEK_TOTAL")"
        emit_row "app:$app_key:$selected_date" "$(app_row_markup "$app_name" "$app_seconds" "$WEEK_TOP_SECONDS" "$app_percent")" "$app_icon"
      done
      emit_row "refresh:week:$selected_date" "$(action_row_markup "Refresh")" "view-refresh-symbolic"
      emit_row "close" "$(action_row_markup "Close")" "window-close-symbolic"
      ;;
    app)
      emit_row "nav:prev-day-app:$(date -d "$selected_date -1 day" +%F):$APP_FILTER" "$(action_row_markup "Previous day" "$(date -d "$selected_date -1 day" '+%a %d %b')")" "go-previous-symbolic"
      if [ "$selected_date" != "$today" ]; then
        emit_row "nav:next-day-app:$(date -d "$selected_date +1 day" +%F):$APP_FILTER" "$(action_row_markup "Next day" "$(date -d "$selected_date +1 day" '+%a %d %b')")" "go-next-symbolic"
      fi
      emit_row "view:day:$selected_date" "$(action_row_markup "Back to day" "$DAY_TITLE")" "go-home-symbolic"
      emit_row "view:week:$selected_date" "$(action_row_markup "Week view" "$WEEK_RANGE_LABEL")" "view-calendar-week"
      emit_row "refresh:app:$selected_date:$APP_FILTER" "$(action_row_markup "Refresh")" "view-refresh-symbolic"
      emit_row "close" "$(action_row_markup "Close")" "window-close-symbolic"
      ;;
  esac
}

PAYLOAD_JSON="$(build_json_payload)"
case "$FORMAT" in
  json)
    printf '%s\n' "$PAYLOAD_JSON"
    ;;
  theme)
    render_theme "$PAYLOAD_JSON"
    ;;
  rows)
    render_rows "$PAYLOAD_JSON"
    ;;
esac
