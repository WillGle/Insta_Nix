render_rows() {
  local json="$1"
  local selected_date
  local today
  local app_json=""
  local app_key=""
  local app_name=""
  local app_icon=""
  local app_seconds=0
  local app_percent=""
  local app_sessions=0
  local app_slots_json=""
  local app_window=""
  local app_spark_json=""
  local detail=""
  local days_active=0
  local app_daily_json=""
  local average_seconds=0

  selected_date="$(printf '%s' "$json" | jq -r '.target_date')"
  today="$(date +%F)"

  case "$VIEW" in
    day)
      emit_row "nav:prev-day:$(date -d "$selected_date -1 day" +%F)" "$(action_row_markup "Previous day" "$(date -d "$selected_date -1 day" '+%a %d %b')")" "go-previous-symbolic"
      if [ "$selected_date" != "$today" ]; then
        emit_row "nav:next-day:$(date -d "$selected_date +1 day" +%F)" "$(action_row_markup "Next day" "$(date -d "$selected_date +1 day" '+%a %d %b')")" "go-next-symbolic"
      fi
      emit_row "view:week:$selected_date" "$(action_row_markup "Week view" "$WEEK_RANGE_LABEL")" "view-calendar-week"
      if [ "$(printf '%s' "$json" | jq -r '.has_any_data')" = "true" ]; then
        printf '%s' "$json" | jq -c '.day_apps[:8][]' | while IFS= read -r app_json; do
          app_key="$(printf '%s' "$app_json" | jq -r '.key')"
          app_name="$(printf '%s' "$app_json" | jq -r '.name')"
          app_icon="$(printf '%s' "$app_json" | jq -r '.icon // empty')"
          app_seconds="$(printf '%s' "$app_json" | jq -r '.seconds // 0')"
          app_percent="$(printf '%s' "$app_json" | jq -r '((.percent // 0) | floor | tostring) + "%"' )"
          app_slots_json="$(printf '%s' "$app_json" | jq -c '.slots_30m // ([range(0; 48)] | map(0))')"
          app_sessions="$(printf '%s' "$app_json" | jq -r '.session_count // empty')"
          if [ -z "$app_sessions" ] || [ "$app_sessions" = "null" ]; then
            app_sessions="$(count_nonzero_runs_json "$app_slots_json")"
          fi
          app_window="$(focus_window_label "$app_slots_json")"
          app_spark_json="$(bucket_values_json "$app_slots_json" 4)"
          detail="$app_window • $(count_label "$app_sessions" "session")"
          emit_row "app:$app_key:$selected_date" "$(app_row_markup "$app_name" "$(seconds_to_short "$app_seconds")" "$app_percent" "$detail" "$(sparkline_from_json "$app_spark_json")")" "$app_icon"
        done
      fi
      emit_row "refresh:day:$selected_date" "$(action_row_markup "Refresh")" "view-refresh-symbolic"
      emit_row "close" "$(action_row_markup "Close")" "window-close-symbolic"
      ;;
    week)
      emit_row "nav:prev-week:$(date -d "$selected_date -7 days" +%F)" "$(action_row_markup "Previous week" "$(date -d "$selected_date -7 days" '+%d %b')")" "go-previous-symbolic"
      if [ "$(date -d "$selected_date +7 days" +%F)" \< "$(date -d "$today +1 day" +%F)" ]; then
        emit_row "nav:next-week:$(date -d "$selected_date +7 days" +%F)" "$(action_row_markup "Next week" "$(date -d "$selected_date +7 days" '+%d %b')")" "go-next-symbolic"
      fi
      emit_row "view:day:$selected_date" "$(action_row_markup "Back to day" "$DAY_TITLE")" "go-home-symbolic"
      printf '%s' "$json" | jq -c '.week_apps[:8][]' | while IFS= read -r app_json; do
        app_key="$(printf '%s' "$app_json" | jq -r '.key')"
        app_name="$(printf '%s' "$app_json" | jq -r '.name')"
        app_icon="$(printf '%s' "$app_json" | jq -r '.icon // empty')"
        app_seconds="$(printf '%s' "$app_json" | jq -r '.seconds // 0')"
        app_percent="$(percent_label "$app_seconds" "$WEEK_TOTAL")"
        days_active="$(printf '%s' "$app_json" | jq -r '.days_active // 0')"
        app_daily_json="$(app_daily_totals_json "$WEEK_START" "$WEEK_END" "$app_key")"
        if [ "$days_active" -gt 0 ]; then
          average_seconds=$((app_seconds / days_active))
        else
          average_seconds=0
        fi
        detail="$(count_label "$days_active" "active day") • avg $(seconds_to_short "$average_seconds")"
        emit_row "app:$app_key:$selected_date" "$(app_row_markup "$app_name" "$(seconds_to_short "$app_seconds")" "$app_percent" "$detail" "$(sparkline_from_json "$app_daily_json")")" "$app_icon"
      done
      emit_row "refresh:week:$selected_date" "$(action_row_markup "Refresh")" "view-refresh-symbolic"
      emit_row "close" "$(action_row_markup "Close")" "window-close-symbolic"
      ;;
    app)
      emit_row "nav:prev-day-app:$(date -d "$selected_date -1 day" +%F):$APP_FILTER" "$(action_row_markup "Previous day" "$(date -d "$selected_date -1 day" '+%a %d %b')")" "go-previous-symbolic"
      if [ "$selected_date" != "$today" ]; then
        emit_row "nav:next-day-app:$(date -d "$selected_date +1 day" +%F):$APP_FILTER" "$(action_row_markup "Next day" "$(date -d "$selected_date +1 day" '+%a %d %b')")" "go-next-symbolic"
      fi
      emit_row "view:day:$selected_date" "$(action_row_markup "Back to day" "$DAY_TITLE")" "go-home-symbolic"
      emit_row "view:week:$selected_date" "$(action_row_markup "Week view" "$WEEK_RANGE_LABEL")" "view-calendar-week"
      printf '%s' "$json" | jq -c --arg current "$APP_FILTER" '.day_apps | map(select(.key != $current))[:6][]' | while IFS= read -r app_json; do
        app_key="$(printf '%s' "$app_json" | jq -r '.key')"
        app_name="$(printf '%s' "$app_json" | jq -r '.name')"
        app_icon="$(printf '%s' "$app_json" | jq -r '.icon // empty')"
        app_seconds="$(printf '%s' "$app_json" | jq -r '.seconds // 0')"
        app_percent="$(printf '%s' "$app_json" | jq -r '((.percent // 0) | floor | tostring) + "%"' )"
        app_slots_json="$(printf '%s' "$app_json" | jq -c '.slots_30m // ([range(0; 48)] | map(0))')"
        app_sessions="$(printf '%s' "$app_json" | jq -r '.session_count // empty')"
        if [ -z "$app_sessions" ] || [ "$app_sessions" = "null" ]; then
          app_sessions="$(count_nonzero_runs_json "$app_slots_json")"
        fi
        app_window="$(focus_window_label "$app_slots_json")"
        app_spark_json="$(bucket_values_json "$app_slots_json" 4)"
        detail="$app_window • $(count_label "$app_sessions" "session")"
        emit_row "app:$app_key:$selected_date" "$(app_row_markup "$app_name" "$(seconds_to_short "$app_seconds")" "$app_percent" "$detail" "$(sparkline_from_json "$app_spark_json")")" "$app_icon"
      done
      emit_row "refresh:app:$selected_date:$APP_FILTER" "$(action_row_markup "Refresh")" "view-refresh-symbolic"
      emit_row "close" "$(action_row_markup "Close")" "window-close-symbolic"
      ;;
  esac
}

render_files() {
  local json="$1"
  local theme_tmp=""
  local rows_tmp=""

  theme_tmp="$(mktemp "${THEME_FILE}.XXXXXX")"
  rows_tmp="$(mktemp "${ROWS_FILE}.XXXXXX")"
  render_theme "$json" >"$theme_tmp"
  render_rows "$json" >"$rows_tmp"
  mv "$theme_tmp" "$THEME_FILE"
  mv "$rows_tmp" "$ROWS_FILE"
}

PAYLOAD_JSON="$(build_json_payload)"
case "$FORMAT" in
  json)
    printf '%s\n' "$PAYLOAD_JSON"
    ;;
  theme)
    render_theme "$PAYLOAD_JSON"
    ;;
  rows)
    render_rows "$PAYLOAD_JSON"
    ;;
  files)
    render_files "$PAYLOAD_JSON"
    ;;
esac
