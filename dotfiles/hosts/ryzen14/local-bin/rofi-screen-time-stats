#!/usr/bin/env bash
set -euo pipefail

export PATH="/run/current-system/sw/bin:/etc/profiles/per-user/${USER:-$(id -un)}/bin:${HOME}/.nix-profile/bin:${PATH}"

SCREEN_TIME_HOME="${SCREEN_TIME_HOME:-${HOME}/.local/share/rofi-screen-time}"
SCREEN_TIME_CACHE_HOME="${SCREEN_TIME_CACHE_HOME:-${HOME}/.cache/rofi-screen-time}"
THEME_STATIC_ENV="${HOME}/.config/theme/static.env"

if [ -r "$THEME_STATIC_ENV" ]; then
  # shellcheck disable=SC1090
  . "$THEME_STATIC_ENV"
fi

BASE_COLOR="${THEME_STATIC_BASE:-#11140f}"
MANTLE_COLOR="${THEME_STATIC_MANTLE:-#1d211b}"
TEXT_COLOR="${THEME_STATIC_TEXT:-#e1e4da}"
SUBTEXT_COLOR="${THEME_STATIC_SUBTEXT:-#c3c8bc}"
ACCENT_COLOR="${THEME_STATIC_ACCENT:-#a7d293}"
SUCCESS_COLOR="${THEME_STATIC_SUCCESS:-#bccbb1}"
WARNING_COLOR="${THEME_STATIC_WARNING:-#d29922}"
ERROR_COLOR="${THEME_STATIC_ERROR:-#f85149}"
PURPLE_COLOR="${THEME_STATIC_PURPLE:-#a0cfd1}"
CYAN_COLOR="${THEME_STATIC_CYAN:-#8fc0ff}"

CACHE_FILE="${SCREEN_TIME_CACHE_HOME}/desktop-cache.tsv"
VIEW="day"
FORMAT="json"
TARGET_DATE="$(date +%F)"
APP_FILTER=""
APP_VIEW_EMPTY=false
THEME_FILE=""
ROWS_FILE=""

usage() {
  cat <<'EOF'
Usage: rofi-screen-time-stats [--date YYYY-MM-DD] [--view day|week|app] [--app APP_CLASS] [--format json|theme|rows|files] [--theme-file PATH --rows-file PATH]
EOF
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

normalize_class() {
  local value
  value="$(trim "${1,,}")"
  value="${value%.exe}"
  value="${value%-updater}"
  value="${value%_updater}"
  value="${value% updater}"
  printf '%s\n' "$value"
}

humanize_class() {
  local value="${1//[_-]/ }"
  local out=""
  local word=""
  for word in $value; do
    out+="${word^} "
  done
  printf '%s\n' "${out%" "}"
}

escape_markup() {
  local value="${1//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  printf '%s\n' "$value"
}

rasi_quote() {
  jq -Rn --arg value "$1" '$value'
}

seconds_to_compact() {
  local total="${1:-0}"
  local hours=$((total / 3600))
  local minutes=$(((total % 3600) / 60))

  if [ "$total" -gt 0 ] && [ "$hours" -eq 0 ] && [ "$minutes" -eq 0 ]; then
    printf '~1m\n'
    return 0
  fi
  if [ "$hours" -gt 0 ]; then
    printf '%dh %02dm\n' "$hours" "$minutes"
    return 0
  fi
  printf '%dm\n' "$minutes"
}

seconds_to_short() {
  local total="${1:-0}"
  local hours=$((total / 3600))
  local minutes=$(((total % 3600) / 60))

  if [ "$total" -gt 0 ] && [ "$hours" -eq 0 ] && [ "$minutes" -eq 0 ]; then
    printf '~1m\n'
    return 0
  fi
  if [ "$hours" -gt 0 ] && [ "$minutes" -gt 0 ]; then
    printf '%dh %dm\n' "$hours" "$minutes"
    return 0
  fi
  if [ "$hours" -gt 0 ]; then
    printf '%dh\n' "$hours"
    return 0
  fi
  printf '%dm\n' "$minutes"
}

percent_label() {
  local numerator="$1"
  local denominator="$2"
  if [ "$denominator" -le 0 ]; then
    printf '0%%\n'
    return 0
  fi
  printf '%d%%\n' $(( (numerator * 100) / denominator ))
}

count_label() {
  local count="${1:-0}"
  local singular="$2"
  local plural="${3:-${2}s}"
  if [ "$count" -eq 1 ]; then
    printf '%d %s\n' "$count" "$singular"
    return 0
  fi
  printf '%d %s\n' "$count" "$plural"
}

delta_label() {
  local delta="${1:-0}"
  local arrow="→"
  if [ "$delta" -gt 0 ]; then
    arrow="↑"
  elif [ "$delta" -lt 0 ]; then
    arrow="↓"
  fi
  printf '%s %s\n' "$arrow" "$(seconds_to_short "${delta#-}")"
}

date_title() {
  local target="$1"
  local today
  local yesterday
  today="$(date +%F)"
  yesterday="$(date -d "$today -1 day" +%F)"

  if [ "$target" = "$today" ]; then
    printf 'Today\n'
  elif [ "$target" = "$yesterday" ]; then
    printf 'Yesterday\n'
  else
    date -d "$target" '+%a %d %b'
  fi
}

day_file() {
  printf '%s/days/%s.json\n' "$SCREEN_TIME_HOME" "$1"
}

study_active_file() {
  printf '%s/study-active.json\n' "$SCREEN_TIME_HOME"
}

epoch_from_iso() {
  date -d "$1" +%s 2>/dev/null || printf '0\n'
}

study_day_seconds() {
  local target="$1"
  local file
  file="$(day_file "$target")"
  [ -f "$file" ] || {
    printf '0\n'
    return 0
  }
  jq -r '.study.total_seconds // 0' "$file"
}

study_day_sessions() {
  local target="$1"
  local file
  file="$(day_file "$target")"
  [ -f "$file" ] || {
    printf '0\n'
    return 0
  }
  jq -r '.study.session_count // 0' "$file"
}

study_active_json() {
  local file
  local started_at=""
  local started_date=""
  local start_epoch=0
  local current_epoch=0
  local elapsed=0

  file="$(study_active_file)"
  if [ ! -f "$file" ]; then
    jq -n '{active:false, started_at:"", started_date:"", elapsed_seconds:0}'
    return 0
  fi
  if ! jq -e '.active == true and (.started_at // "" | length > 0)' "$file" >/dev/null 2>&1; then
    jq -n '{active:false, started_at:"", started_date:"", elapsed_seconds:0}'
    return 0
  fi

  started_at="$(jq -r '.started_at // empty' "$file")"
  start_epoch="$(epoch_from_iso "$started_at")"
  if [ "$start_epoch" -le 0 ]; then
    jq -n '{active:false, started_at:"", started_date:"", elapsed_seconds:0}'
    return 0
  fi

  current_epoch="$(date +%s)"
  if [ "$current_epoch" -gt "$start_epoch" ]; then
    elapsed=$((current_epoch - start_epoch))
  fi
  started_date="$(date -d "$started_at" +%F)"

  jq -n \
    --arg started_at "$started_at" \
    --arg started_date "$started_date" \
    --argjson elapsed_seconds "$elapsed" \
    '{active:true, started_at:$started_at, started_date:$started_date, elapsed_seconds:$elapsed_seconds}'
}

study_active_overlap_seconds() {
  local range_start="$1"
  local range_end="$2"
  local range_start_epoch=0
  local range_end_epoch=0
  local overlap_start=0
  local overlap_end=0

  if [ "${STUDY_TIMER_ACTIVE:-false}" != "true" ]; then
    printf '0\n'
    return 0
  fi

  range_start_epoch="$(date -d "$range_start 00:00:00" +%s)"
  range_end_epoch="$(date -d "$range_end +1 day 00:00:00" +%s)"
  overlap_start="$STUDY_TIMER_STARTED_EPOCH"
  if [ "$range_start_epoch" -gt "$overlap_start" ]; then
    overlap_start="$range_start_epoch"
  fi
  overlap_end="$STUDY_TIMER_NOW_EPOCH"
  if [ "$range_end_epoch" -lt "$overlap_end" ]; then
    overlap_end="$range_end_epoch"
  fi

  if [ "$overlap_end" -le "$overlap_start" ]; then
    printf '0\n'
  else
    printf '%d\n' $((overlap_end - overlap_start))
  fi
}

study_range_seconds() {
  local range_start="$1"
  local range_end="$2"
  local cursor="$range_start"
  local total=0

  while :; do
    total=$((total + $(study_day_seconds "$cursor")))
    if [ "$cursor" = "$range_end" ]; then
      break
    fi
    cursor="$(date -d "$cursor +1 day" +%F)"
  done

  total=$((total + $(study_active_overlap_seconds "$range_start" "$range_end")))
  printf '%d\n' "$total"
}

study_range_sessions() {
  local range_start="$1"
  local range_end="$2"
  local cursor="$range_start"
  local total=0

  while :; do
    total=$((total + $(study_day_sessions "$cursor")))
    if [ "$cursor" = "$range_end" ]; then
      break
    fi
    cursor="$(date -d "$cursor +1 day" +%F)"
  done

  printf '%d\n' "$total"
}

time_from_minutes() {
  local minutes="${1:-0}"
  printf '%02d:%02d\n' $((minutes / 60)) $((minutes % 60))
}

slot_start_label() {
  local slot="${1:-0}"
  time_from_minutes $((slot * 30))
}

slot_end_label() {
  local slot="${1:-0}"
  time_from_minutes $(((slot + 1) * 30))
}

slot_range_label() {
  local slot="${1:-0}"
  printf '%s-%s\n' "$(slot_start_label "$slot")" "$(slot_end_label "$slot")"
}

build_desktop_cache() {
  if [ -s "$CACHE_FILE" ]; then
    return 0
  fi
  mkdir -p "$SCREEN_TIME_CACHE_HOME"

  local tmp
  local xdg_data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
  local xdg_data_dirs="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
  local data_dir=""
  local search_dirs=("$xdg_data_home/applications")
  local dir=""
  local desktop=""
  local name=""
  local icon=""
  local wmclass=""
  local key=""
  tmp="$(mktemp)"

  for data_dir in ${xdg_data_dirs//:/ }; do
    search_dirs+=("$data_dir/applications")
  done
  search_dirs+=(
    "/var/lib/flatpak/exports/share/applications"
    "/var/lib/snapd/desktop/applications"
  )

  {
    for dir in "${search_dirs[@]}"; do
      [ -d "$dir" ] || continue
      while IFS= read -r -d '' desktop; do
        name=""
        icon=""
        wmclass=""
        while IFS= read -r line; do
          case "$line" in
            Name=*)
              [ -n "$name" ] || name="${line#Name=}"
              ;;
            Icon=*)
              [ -n "$icon" ] || icon="${line#Icon=}"
              ;;
            StartupWMClass=*)
              [ -n "$wmclass" ] || wmclass="${line#StartupWMClass=}"
              ;;
          esac
        done <"$desktop"

        if [ -z "$name" ]; then
          continue
        fi
        key="$(normalize_class "$(basename "$desktop" .desktop)")"
        if [ -n "$key" ]; then
          printf '%s\t%s\t%s\n' "$key" "$name" "$icon"
        fi
        if [ -n "$wmclass" ]; then
          key="$(normalize_class "$wmclass")"
          if [ -n "$key" ]; then
            printf '%s\t%s\t%s\n' "$key" "$name" "$icon"
          fi
        fi
      done < <(find "$dir" -maxdepth 1 -type f -name '*.desktop' -print0 2>/dev/null)
    done
  } | awk -F '\t' '!seen[$1]++' >"$tmp"

  mv "$tmp" "$CACHE_FILE"
}

resolve_app_meta() {
  local app_key="$1"
  local name=""
  local icon=""

  build_desktop_cache
  if [ -s "$CACHE_FILE" ]; then
    name="$(awk -F '\t' -v key="$app_key" '$1 == key { print $2; exit }' "$CACHE_FILE")"
    icon="$(awk -F '\t' -v key="$app_key" '$1 == key { print $3; exit }' "$CACHE_FILE")"
  fi

  if [ -z "$name" ]; then
    name="$(humanize_class "$app_key")"
  fi
  printf '%s\t%s\n' "$name" "$icon"
}

day_total() {
  local target="$1"
  local app_key="${2:-}"
  local file
  file="$(day_file "$target")"

  [ -f "$file" ] || {
    printf '0\n'
    return 0
  }

  if [ -n "$app_key" ]; then
    jq -r --arg app "$app_key" '(.apps[$app].seconds // 0)' "$file"
  else
    jq -r '(.total_seconds // 0)' "$file"
  fi
}

day_slots_json() {
  local target="$1"
  local app_key="${2:-}"
  local file
  file="$(day_file "$target")"

  [ -f "$file" ] || {
    jq -nc '[range(0; 48) | 0]'
    return 0
  }

  if [ -n "$app_key" ]; then
    jq -c --arg app "$app_key" '(.apps[$app].slots_30m // ([range(0; 48)] | map(0)))' "$file"
  else
    jq -c '(.slots_30m // ([range(0; 48)] | map(0)))' "$file"
  fi
}

day_apps_json() {
  local target="$1"
  local file
  file="$(day_file "$target")"

  [ -f "$file" ] || {
    printf '[]\n'
    return 0
  }

  jq -c '
    (.total_seconds // 0) as $total
    | (.apps // {})
    | to_entries
    | map(
        .value
        + {
            key: .key,
            percent: (if $total > 0 then ((.value.seconds // 0) * 100 / $total) else 0 end)
          }
      )
    | sort_by(-.seconds, .name)
  ' "$file"
}

week_apps_json() {
  local week_start="$1"
  local week_end="$2"
  local files=()
  local cursor="$week_start"
  local file=""

  while :; do
    file="$(day_file "$cursor")"
    if [ -f "$file" ]; then
      files+=("$file")
    fi
    if [ "$cursor" = "$week_end" ]; then
      break
    fi
    cursor="$(date -d "$cursor +1 day" +%F)"
  done

  [ "${#files[@]}" -gt 0 ] || {
    printf '[]\n'
    return 0
  }

  jq -sc '
    reduce .[] as $day ({};
      reduce (($day.apps // {}) | to_entries[]) as $entry (.;
        .[$entry.key] = (
          (.[$entry.key] // {
            key: $entry.key,
            class: ($entry.value.class // $entry.key),
            name: ($entry.value.name // $entry.key),
            icon: ($entry.value.icon // ""),
            seconds: 0,
            sample_count: 0,
            session_count: 0,
            days_active: 0
          })
          | .seconds += ($entry.value.seconds // 0)
          | .sample_count += ($entry.value.sample_count // 0)
          | .session_count += ($entry.value.session_count // 0)
          | .days_active += (if ($entry.value.seconds // 0) > 0 then 1 else 0 end)
        )
      )
    )
    | to_entries
    | map(.value)
    | sort_by(-.seconds, .name)
  ' "${files[@]}"
}

week_slots_json() {
  local week_start="$1"
  local week_end="$2"
  local app_key="${3:-}"
  local files=()
  local cursor="$week_start"
  local file=""

  while :; do
    file="$(day_file "$cursor")"
    if [ -f "$file" ]; then
      files+=("$file")
    fi
    if [ "$cursor" = "$week_end" ]; then
      break
    fi
    cursor="$(date -d "$cursor +1 day" +%F)"
  done

  [ "${#files[@]}" -gt 0 ] || {
    jq -nc '[range(0; 48) | 0]'
    return 0
  }

  if [ -n "$app_key" ]; then
    jq -sc --arg app "$app_key" '
      reduce .[] as $day (([range(0; 48)] | map(0));
        [range(0; 48) as $i | .[$i] + (($day.apps[$app].slots_30m[$i] // 0))]
      )
    ' "${files[@]}"
  else
    jq -sc '
      reduce .[] as $day (([range(0; 48)] | map(0));
        [range(0; 48) as $i | .[$i] + (($day.slots_30m[$i] // 0))]
      )
    ' "${files[@]}"
  fi
}

app_daily_totals_json() {
  local week_start="$1"
  local week_end="$2"
  local app_key="$3"
  local cursor="$week_start"
  local totals=()

  while :; do
    totals+=("$(day_total "$cursor" "$app_key")")
    if [ "$cursor" = "$week_end" ]; then
      break
    fi
    cursor="$(date -d "$cursor +1 day" +%F)"
  done

  printf '%s\n' "${totals[@]}" | jq -Rsc 'split("\n") | map(select(length > 0) | tonumber)'
}

day_updated_at() {
  local target="$1"
  local file
  file="$(day_file "$target")"
  [ -f "$file" ] || {
    printf '\n'
    return 0
  }
  jq -r '.updated_at // empty' "$file"
}

day_sample_seconds() {
  local target="$1"
  local file
  file="$(day_file "$target")"
  [ -f "$file" ] || {
    printf '0\n'
    return 0
  }
  jq -r '.sample_seconds // 0' "$file"
}

day_sample_count() {
  local target="$1"
  local app_key="${2:-}"
  local file
  local direct=""
  local sample_seconds=0
  local total=0

  file="$(day_file "$target")"
  [ -f "$file" ] || {
    printf '0\n'
    return 0
  }

  if [ -n "$app_key" ]; then
    direct="$(jq -r --arg app "$app_key" '.apps[$app].sample_count // empty' "$file")"
  else
    direct="$(jq -r '.sample_count // empty' "$file")"
  fi

  if [ -n "$direct" ] && [ "$direct" != "null" ]; then
    printf '%s\n' "$direct"
    return 0
  fi

  sample_seconds="$(day_sample_seconds "$target")"
  total="$(day_total "$target" "$app_key")"
  if [ "$sample_seconds" -gt 0 ]; then
    printf '%d\n' $((total / sample_seconds))
  else
    printf '0\n'
  fi
}

active_slot_count_json() {
  printf '%s' "$1" | jq -r 'map(select(. > 0)) | length'
}

count_nonzero_runs_json() {
  printf '%s' "$1" | jq -r '
    reduce .[] as $value ({count: 0, active: false};
      if $value > 0 then
        .count += (if .active then 0 else 1 end)
        | .active = true
      else
        .active = false
      end
    )
    | .count
  '
}

first_active_index_json() {
  printf '%s' "$1" | jq -r '([to_entries[] | select(.value > 0) | .key] | first // -1)'
}

last_active_index_json() {
  printf '%s' "$1" | jq -r '([to_entries[] | select(.value > 0) | .key] | last // -1)'
}

peak_slot_info() {
  printf '%s' "$1" | jq -r '
    [to_entries[] | select(.value > 0)]
    | if length == 0 then
        "-1\t0"
      else
        (max_by(.value) | "\(.key)\t\(.value)")
      end
  '
}

focus_window_label() {
  local slots_json="$1"
  local first_index
  local last_index

  first_index="$(first_active_index_json "$slots_json")"
  last_index="$(last_active_index_json "$slots_json")"
  if [ "$first_index" -lt 0 ] || [ "$last_index" -lt 0 ]; then
    printf 'No tracked focus\n'
    return 0
  fi
  printf '%s-%s\n' "$(slot_start_label "$first_index")" "$(slot_end_label "$last_index")"
}

day_session_count() {
  local target="$1"
  local app_key="${2:-}"
  local file
  local direct=""
  local slots_json=""

  file="$(day_file "$target")"
  [ -f "$file" ] || {
    printf '0\n'
    return 0
  }

  if [ -n "$app_key" ]; then
    direct="$(jq -r --arg app "$app_key" '.apps[$app].session_count // empty' "$file")"
  else
    direct="$(jq -r '.session_count // empty' "$file")"
  fi

  if [ -n "$direct" ] && [ "$direct" != "null" ]; then
    printf '%s\n' "$direct"
    return 0
  fi

  slots_json="$(day_slots_json "$target" "$app_key")"
  count_nonzero_runs_json "$slots_json"
}

updated_time_label() {
  local timestamp="$1"
  if [ -z "$timestamp" ]; then
    printf 'No samples\n'
    return 0
  fi
  date -d "$timestamp" '+%H:%M'
}

streak_days() {
  local cursor="$1"
  local app_key="${2:-}"
  local total=0
  local count=0

  while :; do
    total="$(day_total "$cursor" "$app_key")"
    [ "$total" -gt 0 ] || break
    count=$((count + 1))
    cursor="$(date -d "$cursor -1 day" +%F)"
  done

  printf '%d\n' "$count"
}

bucket_values_json() {
  local values_json="$1"
  local bucket_size="${2:-4}"
  printf '%s' "$values_json" | jq -c --argjson size "$bucket_size" '
    [range(0; length; $size) as $i | (.[ $i : ($i + $size) ] | add // 0)]
  '
}

bar_markup() {
  local value="${1:-0}"
  local max="${2:-0}"
  local width="${3:-12}"
  local fill_color="${4:-$ACCENT_COLOR}"
  local empty_color="${5:-$MANTLE_COLOR}"
  local filled=0
  local out=""
  local i=0

  if [ "$max" -gt 0 ]; then
    filled=$((value * width / max))
  fi
  if [ "$filled" -le 0 ] && [ "$value" -gt 0 ]; then
    filled=1
  fi

  while [ "$i" -lt "$filled" ]; do
    out+="<span foreground=\"$fill_color\">█</span>"
    i=$((i + 1))
  done
  while [ "$i" -lt "$width" ]; do
    out+="<span foreground=\"$empty_color\">█</span>"
    i=$((i + 1))
  done

  printf '%s\n' "$out"
}

sparkline_from_json() {
  local values_json="$1"
  local highlight_index="${2:-}"
  local length
  local max
  local index=0
  local value=0
  local glyph=""
  local out=""
  local chars=(▁ ▂ ▃ ▄ ▅ ▆ ▇ █)
  local color=""

  length="$(printf '%s' "$values_json" | jq 'length')"
  max="$(printf '%s' "$values_json" | jq 'max // 0')"
  if [ "$length" -le 0 ]; then
    printf '\n'
    return 0
  fi

  while [ "$index" -lt "$length" ]; do
    value="$(printf '%s' "$values_json" | jq -r ".[$index] // 0")"
    if [ "$max" -le 0 ]; then
      glyph="${chars[0]}"
    else
      glyph="${chars[$((value * 7 / max))]}"
    fi

    if [ "$value" -le 0 ]; then
      color="$MANTLE_COLOR"
    else
      color="$CYAN_COLOR"
    fi
    if [ -n "$highlight_index" ] && [ "$index" -eq "$highlight_index" ]; then
      color="$ACCENT_COLOR"
    fi
    out+="<span foreground=\"$color\">$glyph</span>"
    index=$((index + 1))
  done

  printf '%s\n' "$out"
}

render_timeline_chart() {
  local slots_json="$1"
  local detail="$2"
  local peak_info
  local peak_index
  local highlight=""

  peak_info="$(peak_slot_info "$slots_json")"
  peak_index="${peak_info%%$'\t'*}"
  if [ "$peak_index" -ge 0 ]; then
    highlight="$peak_index"
  fi

  printf '<span foreground="%s" size="small">00        06        12        18        24</span>\n%s\n<span foreground="%s" size="small">%s</span>\n' \
    "$SUBTEXT_COLOR" \
    "$(sparkline_from_json "$slots_json" "$highlight")" \
    "$SUBTEXT_COLOR" \
    "$(escape_markup "$detail")"
}

render_week_pulse() {
  local week_json="$1"
  local length
  local index=0
  local day=""
  local total=0
  local is_target="false"
  local max_total=0
  local label_color=""
  local bar_color=""
  local output=""

  max_total="$(printf '%s' "$week_json" | jq -r 'map(.total) | max // 0')"
  length="$(printf '%s' "$week_json" | jq 'length')"
  while [ "$index" -lt "$length" ]; do
    day="$(printf '%s' "$week_json" | jq -r ".[$index].day")"
    total="$(printf '%s' "$week_json" | jq -r ".[$index].total")"
    is_target="$(printf '%s' "$week_json" | jq -r ".[$index].is_target")"

    label_color="$SUBTEXT_COLOR"
    bar_color="$SUCCESS_COLOR"
    if [ "$is_target" = "true" ]; then
      label_color="$ACCENT_COLOR"
      bar_color="$ACCENT_COLOR"
    fi

    output+="<span foreground=\"$label_color\">$day</span>  "
    output+="$(bar_markup "$total" "$max_total" 11 "$bar_color" "$MANTLE_COLOR")"
    output+="  <span foreground=\"$TEXT_COLOR\">$(seconds_to_short "$total")</span>"
    if [ "$index" -lt $((length - 1)) ]; then
      output+=$'\n'
    fi

    index=$((index + 1))
  done

  printf '%s\n' "$output"
}

heatmap_color() {
  local total="$1"
  if [ "$total" -le 0 ]; then
    printf '%s\n' "$MANTLE_COLOR"
  elif [ "$total" -lt 1800 ]; then
    printf '%s\n' "$SUCCESS_COLOR"
  elif [ "$total" -lt 5400 ]; then
    printf '%s\n' "$ACCENT_COLOR"
  elif [ "$total" -lt 14400 ]; then
    printf '%s\n' "$CYAN_COLOR"
  else
    printf '%s\n' "$TEXT_COLOR"
  fi
}

render_month_heatmap() {
  local month_json="$1"
  local target="$2"
  local length
  local index=0
  local cell_date=""
  local cell_total=0
  local line=""
  local output='<span foreground="'"$SUBTEXT_COLOR"'" size="small">Mo Tu We Th Fr Sa Su</span>'
  local day_text=""
  local color=""

  length="$(printf '%s' "$month_json" | jq 'length')"
  while [ "$index" -lt "$length" ]; do
    if [ $((index % 7)) -eq 0 ]; then
      line=""
    fi

    cell_date="$(printf '%s' "$month_json" | jq -r ".[$index].date")"
    cell_total="$(printf '%s' "$month_json" | jq -r ".[$index].total")"

    if [ -z "$cell_date" ]; then
      line+='   '
    else
      color="$(heatmap_color "$cell_total")"
      day_text="$(date -d "$cell_date" +%d)"
      if [ "$cell_date" = "$target" ]; then
        line+="<span background=\"$TEXT_COLOR\" foreground=\"$BASE_COLOR\">$day_text</span> "
      else
        line+="<span background=\"$color\" foreground=\"$BASE_COLOR\">$day_text</span> "
      fi
    fi

    if [ $((index % 7)) -eq 6 ] || [ "$index" -eq $((length - 1)) ]; then
      output+=$'\n'
      output+="$line"
    fi
    index=$((index + 1))
  done

  printf '%s\n' "$output"
}

kv_markup() {
  local label="$1"
  local value="$2"
  printf '<span foreground="%s">%s</span> <span weight="600">%s</span>' \
    "$SUBTEXT_COLOR" \
    "$(escape_markup "$label")" \
    "$(escape_markup "$value")"
}

action_row_markup() {
  local label="$1"
  local hint="${2:-}"
  if [ -n "$hint" ]; then
    printf '<span weight="600">%s</span>&#10;<span foreground="%s" size="small">%s</span>' \
      "$(escape_markup "$label")" \
      "$SUBTEXT_COLOR" \
      "$(escape_markup "$hint")"
  else
    printf '<span weight="600">%s</span>' "$(escape_markup "$label")"
  fi
}

app_row_markup() {
  local name="$1"
  local primary="$2"
  local secondary="$3"
  local detail="$4"
  local sparkline="$5"

  printf '<span weight="600">%s</span>  <span foreground="%s">%s</span>  <span foreground="%s">%s</span>&#10;<span foreground="%s" size="small">%s</span>&#10;%s' \
    "$(escape_markup "$name")" \
    "$TEXT_COLOR" \
    "$(escape_markup "$primary")" \
    "$SUBTEXT_COLOR" \
    "$(escape_markup "$secondary")" \
    "$SUBTEXT_COLOR" \
    "$(escape_markup "$detail")" \
    "$sparkline"
}

emit_row() {
  local token="$1"
  local display="$2"
  local icon="${3:-}"
  printf '%s' "$token"
  printf '\0display\x1f%s' "$display"
  if [ -n "$icon" ]; then
    printf '\x1ficon\x1f%s' "$icon"
  fi
  printf '\n'
}

