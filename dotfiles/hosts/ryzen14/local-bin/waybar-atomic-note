#!/usr/bin/env bash
set -euo pipefail
# Waybar Atomic Note Display Script
# Idle: [Priority][Task] [Remaining]
# Hover: Top 5 Tasks

TASK_FILE="$HOME/.atomic_tasks"
[ ! -f "$TASK_FILE" ] && jq -cn --arg text "" '{text: $text}' && exit 0

escape_markup() {
    local value="${1//&/&amp;}"
    value="${value//</&lt;}"
    value="${value//>/&gt;}"
    printf '%s\n' "$value"
}

task_priority() {
    local task="$1"
    local lower="${task,,}"
    case "$lower" in
        \[critical\]*|\[a\]*)
            printf '%s\n' "critical"
            ;;
        \[high\]*|\[b\]*)
            printf '%s\n' "high"
            ;;
        \[moderate\]*|\[medium\]*|\[c\]*)
            printf '%s\n' "moderate"
            ;;
        \[low\]*|\[d\]*)
            printf '%s\n' "low"
            ;;
        *)
            printf '%s\n' "moderate"
            ;;
    esac
}

task_body() {
    local task="$1"
    if [[ "$task" =~ ^\[(Critical|High|Moderate|Medium|Low|A|B|C|D)\][[:space:]]*(.*)$ ]]; then
        printf '%s\n' "${BASH_REMATCH[2]}"
        return 0
    fi
    printf '%s\n' "$task"
}

priority_icon() {
    case "$1" in
        critical)
            printf '%s\n' "󰀦"
            ;;
        high)
            printf '%s\n' "󰳟"
            ;;
        moderate)
            printf '%s\n' "󰗠"
            ;;
        low)
            printf '%s\n' "󰾆"
            ;;
    esac
}

priority_label() {
    case "$1" in
        critical)
            printf '%s\n' "Critical"
            ;;
        high)
            printf '%s\n' "High"
            ;;
        moderate)
            printf '%s\n' "Moderate"
            ;;
        low)
            printf '%s\n' "Low"
            ;;
    esac
}

# Read all tasks
tasks=()
while IFS= read -r line; do
    [ -n "$line" ] && tasks+=("$line")
done < "$TASK_FILE"

count=${#tasks[@]}

if [ "$count" -eq 0 ]; then
    jq -cn \
        --arg text "󰠮 Empty" \
        --arg tooltip "No active tasks" \
        --arg class "empty" \
        '{text: $text, tooltip: $tooltip, class: $class}'
    exit 0
fi

# Top task for main display
top_task="${tasks[0]}"
remaining=$((count - 1))
top_priority="$(task_priority "$top_task")"
top_body="$(task_body "$top_task")"
top_icon="$(priority_icon "$top_priority")"

# Format the text for Waybar: "[Priority][Task] [N remain]"
display_text="$top_icon $top_body"
if [ "$remaining" -gt 0 ]; then
    display_text="$display_text   ($remaining)"
fi

# Tooltip: Top 5 tasks
tooltip=$'<b>Atomic Tasks</b>\n------------------\n'
for ((i=0; i<5 && i<count; i++)); do
    priority="$(task_priority "${tasks[i]}")"
    body="$(task_body "${tasks[i]}")"
    tooltip+="$(priority_label "$priority"): $(escape_markup "$body")"$'\n'
done

if [ "$count" -gt 5 ]; then
    tooltip+="... and $((count - 5)) more"
fi

class="$top_priority"

jq -cn \
    --arg text "󰠮 $display_text" \
    --arg tooltip "$tooltip" \
    --arg class "$class" \
    '{text: $text, tooltip: $tooltip, class: $class}'
