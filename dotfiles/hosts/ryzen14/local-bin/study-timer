#!/usr/bin/env bash
set -euo pipefail

export PATH="/run/current-system/sw/bin:/etc/profiles/per-user/${USER:-$(id -un)}/bin:${HOME}/.nix-profile/bin:${PATH}"

SCREEN_TIME_HOME="${SCREEN_TIME_HOME:-${XDG_DATA_HOME:-${HOME}/.local/share}/rofi-screen-time}"
SCREEN_TIME_SAMPLE_SECONDS="${SCREEN_TIME_SAMPLE_SECONDS:-5}"
STATE_DIR="$SCREEN_TIME_HOME"
COMMAND="toggle"
FORMAT="text"
CACHE_SERVICE_NAME="${CACHE_SERVICE_NAME:-rofi-screen-time-cache.service}"
WAYBAR_SCREEN_TIME_SIGNAL="${WAYBAR_SCREEN_TIME_SIGNAL:-7}"
DURATION_MINUTES=""
SESSION_COUNT=""
STUDY_MODE=""

usage() {
  cat <<'EOF'
Usage: study-timer [start|stop|toggle|status] [--duration-minutes N] [--session-count N] [--mode NAME] [--format text|json] [--state-dir PATH]
EOF
}

day_file() {
  printf '%s/days/%s.json\n' "$STATE_DIR" "$1"
}

active_file() {
  printf '%s/study-active.json\n' "$STATE_DIR"
}

now_iso() {
  date --iso-8601=seconds
}

seconds_to_short() {
  local total="${1:-0}"
  local hours=$((total / 3600))
  local minutes=$(((total % 3600) / 60))

  if [ "$total" -gt 0 ] && [ "$hours" -eq 0 ] && [ "$minutes" -eq 0 ]; then
    printf '~1m\n'
    return 0
  fi
  if [ "$hours" -gt 0 ] && [ "$minutes" -gt 0 ]; then
    printf '%dh %dm\n' "$hours" "$minutes"
    return 0
  fi
  if [ "$hours" -gt 0 ]; then
    printf '%dh\n' "$hours"
    return 0
  fi
  printf '%dm\n' "$minutes"
}

is_positive_integer() {
  local value="${1:-}"
  case "$value" in
    ''|*[!0-9]*)
      return 1
      ;;
    0)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

plan_label() {
  local duration_minutes="${1:-}"
  local session_count="${2:-}"
  if [ -z "$duration_minutes" ]; then
    printf 'Open-ended session\n'
    return 0
  fi
  if [ -n "$session_count" ]; then
    printf '%sm x %s sessions\n' "$duration_minutes" "$session_count"
    return 0
  fi
  printf '%sm target\n' "$duration_minutes"
}

notify() {
  local title="$1"
  local body="$2"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a "study-timer" "$title" "$body"
  fi
}

refresh_screen_time_cache() {
  systemctl --user start "$CACHE_SERVICE_NAME" >/dev/null 2>&1 || true
}

refresh_waybar_screen_time() {
  pkill -RTMIN+"$WAYBAR_SCREEN_TIME_SIGNAL" waybar >/dev/null 2>&1 || true
}

epoch_from_iso() {
  date -d "$1" +%s 2>/dev/null || printf '0\n'
}

default_day_json() {
  local target_date="$1"
  local current_now="$2"
  local sample="$3"

  jq -n \
    --arg date "$target_date" \
    --arg now "$current_now" \
    --argjson sample "$sample" \
    '{
      version: 2,
      date: $date,
      updated_at: $now,
      sample_seconds: $sample,
      sample_count: 0,
      first_seen: "",
      last_seen: "",
      session_count: 0,
      switch_count: 0,
      last_app: "",
      last_sample_at: "",
      total_seconds: 0,
      slots_30m: ([range(0; 48)] | map(0)),
      apps: {},
      study: {
        total_seconds: 0,
        session_count: 0,
        last_started_at: "",
        last_stopped_at: "",
        active_overlap_seconds: 0
      }
    }'
}

ensure_dirs() {
  mkdir -p "$STATE_DIR/days"
}

ensure_day_file() {
  local target_date="$1"
  local current_now="$2"
  local file
  local tmp
  file="$(day_file "$target_date")"

  if [ ! -f "$file" ]; then
    default_day_json "$target_date" "$current_now" "$SCREEN_TIME_SAMPLE_SECONDS" >"$file"
    return 0
  fi

  tmp="$(mktemp "${file}.XXXXXX")"
  jq --arg now "$current_now" '
    .version = (if (.version // 0) < 2 then 2 else .version end) |
    .study = (.study // {
      total_seconds: 0,
      session_count: 0,
      last_started_at: "",
      last_stopped_at: "",
      active_overlap_seconds: 0
    })
    | .study.active_overlap_seconds = (.study.active_overlap_seconds // 0)
    | .updated_at = (.updated_at // $now)
  ' "$file" >"$tmp"
  mv "$tmp" "$file"
}

study_status_json() {
  local file
  local started_at=""
  local started_date=""
  local start_epoch=0
  local current_epoch=0
  local elapsed=0
  local duration_minutes=""
  local planned_sessions=""
  local per_session_seconds_json="null"
  local planned_total_seconds_json="null"
  local remaining_total_seconds_json="null"
  local current_session_json="null"
  local current_session_elapsed_json="null"
  local current_session_remaining_json="null"
  local target_reached="false"
  local duration_seconds=0
  local planned_total_seconds=0
  local remaining_total_seconds=0
  local current_session=0
  local current_session_elapsed=0
  local current_session_remaining=0
  local mode_json="null"

  file="$(active_file)"
  if [ ! -f "$file" ]; then
    local daily_total=0
    local today_file="$(day_file "$(date +%F)")"
    if [ -f "$today_file" ]; then
      daily_total="$(jq -r '.study.total_seconds // 0' "$today_file")"
    fi
    jq -n --argjson daily_total "$daily_total" '{
      active:false,
      started_at:"",
      started_date:"",
      elapsed_seconds:0,
      duration_minutes:null,
      planned_sessions:null,
      per_session_seconds:null,
      planned_total_seconds:null,
      remaining_total_seconds:null,
      current_session:null,
      current_session_elapsed_seconds:null,
      current_session_remaining_seconds:null,
      target_reached:false,
      mode:null,
      estimated_finish_at:null,
      daily_total_seconds:$daily_total
    }'
    return 0
  fi
  if ! jq -e '.active == true and (.started_at // "" | length > 0)' "$file" >/dev/null 2>&1; then
    local daily_total=0
    local today_file="$(day_file "$(date +%F)")"
    if [ -f "$today_file" ]; then
      daily_total="$(jq -r '.study.total_seconds // 0' "$today_file")"
    fi
    jq -n --argjson daily_total "$daily_total" '{
      active:false,
      started_at:"",
      started_date:"",
      elapsed_seconds:0,
      duration_minutes:null,
      planned_sessions:null,
      per_session_seconds:null,
      planned_total_seconds:null,
      remaining_total_seconds:null,
      current_session:null,
      current_session_elapsed_seconds:null,
      current_session_remaining_seconds:null,
      target_reached:false,
      mode:null,
      estimated_finish_at:null,
      daily_total_seconds:$daily_total
    }'
    return 0
  fi

  started_at="$(jq -r '.started_at // empty' "$file")"
  start_epoch="$(epoch_from_iso "$started_at")"
  if [ "$start_epoch" -le 0 ]; then
    jq -n '{
      active:false,
      started_at:"",
      started_date:"",
      elapsed_seconds:0,
      duration_minutes:null,
      planned_sessions:null,
      per_session_seconds:null,
      planned_total_seconds:null,
      remaining_total_seconds:null,
      current_session:null,
      current_session_elapsed_seconds:null,
      current_session_remaining_seconds:null,
      target_reached:false,
      mode:null
    }'
    return 0
  fi

  current_epoch="$(epoch_from_iso "$(now_iso)")"
  if [ "$current_epoch" -gt "$start_epoch" ]; then
    elapsed=$((current_epoch - start_epoch))
  fi
  started_date="$(date -d "$started_at" +%F)"
  duration_minutes="$(jq -r '.duration_minutes // empty' "$file")"
  planned_sessions="$(jq -r '.planned_sessions // empty' "$file")"
  mode_json="$(jq -c '.mode // null' "$file")"

  if is_positive_integer "$duration_minutes"; then
    duration_seconds=$((duration_minutes * 60))
    per_session_seconds_json="$duration_seconds"
    current_session=$((elapsed / duration_seconds + 1))
    current_session_elapsed=$((elapsed % duration_seconds))
    current_session_remaining=$((duration_seconds - current_session_elapsed))
    if [ "$current_session_remaining" -eq "$duration_seconds" ] && [ "$elapsed" -gt 0 ]; then
      current_session_remaining=0
      current_session_elapsed="$duration_seconds"
    fi
    current_session_json="$current_session"
    current_session_elapsed_json="$current_session_elapsed"
    current_session_remaining_json="$current_session_remaining"

    if is_positive_integer "$planned_sessions"; then
      planned_total_seconds=$((duration_seconds * planned_sessions))
      planned_total_seconds_json="$planned_total_seconds"
      remaining_total_seconds=$((planned_total_seconds - elapsed))
      if [ "$remaining_total_seconds" -le 0 ]; then
        remaining_total_seconds=0
        current_session="$planned_sessions"
        current_session_json="$current_session"
        current_session_elapsed_json="$duration_seconds"
        current_session_remaining_json="0"
        target_reached="true"
      elif [ "$current_session" -gt "$planned_sessions" ]; then
        current_session="$planned_sessions"
        current_session_json="$current_session"
      fi
      remaining_total_seconds_json="$remaining_total_seconds"
    fi
  fi
    if [ -n "$remaining_total_seconds" ] && [ "$remaining_total_seconds" -gt 0 ]; then
      estimated_finish_at="$(date -d "@$((current_epoch + remaining_total_seconds))" --iso-8601=seconds)"
    fi

  local daily_total=0
  local today_file="$(day_file "$(date +%F)")"
  if [ -f "$today_file" ]; then
    daily_total="$(jq -r '.study.total_seconds // 0' "$today_file")"
  fi

  jq -n \
    --arg started_at "$started_at" \
    --arg started_date "$started_date" \
    --argjson elapsed_seconds "$elapsed" \
    --argjson duration_minutes "${duration_minutes:-null}" \
    --argjson planned_sessions "${planned_sessions:-null}" \
    --argjson per_session_seconds "$per_session_seconds_json" \
    --argjson planned_total_seconds "$planned_total_seconds_json" \
    --argjson remaining_total_seconds "$remaining_total_seconds_json" \
    --argjson current_session "$current_session_json" \
    --argjson current_session_elapsed_seconds "$current_session_elapsed_json" \
    --argjson current_session_remaining_seconds "$current_session_remaining_json" \
    --argjson target_reached "$target_reached" \
    --argjson mode "$mode_json" \
    --arg estimated_finish_at "${estimated_finish_at:-}" \
    --argjson daily_total_seconds "$daily_total" \
    '{
      active:true,
      started_at:$started_at,
      started_date:$started_date,
      elapsed_seconds:$elapsed_seconds,
      duration_minutes:$duration_minutes,
      planned_sessions:$planned_sessions,
      per_session_seconds:$per_session_seconds,
      planned_total_seconds:$planned_total_seconds,
      remaining_total_seconds:$remaining_total_seconds,
      current_session:$current_session,
      current_session_elapsed_seconds:$current_session_elapsed_seconds,
      current_session_remaining_seconds:$current_session_remaining_seconds,
      target_reached:$target_reached,
      mode:$mode,
      estimated_finish_at:(if $estimated_finish_at == "" then null else $estimated_finish_at end),
      daily_total_seconds:$daily_total_seconds
    }'
}

print_result() {
  local json="$1"
  local action="${2:-status}"
  local active=""
  local started_at=""
  local elapsed=0

  if [ "$FORMAT" = "json" ]; then
    printf '%s\n' "$json"
    return 0
  fi

  active="$(printf '%s' "$json" | jq -r '.active')"
  started_at="$(printf '%s' "$json" | jq -r '.started_at // empty')"
  elapsed="$(printf '%s' "$json" | jq -r '.elapsed_seconds // 0')"
  local duration_minutes
  local planned_sessions
  local current_session
  local remaining_total_seconds
  local target_reached
  local plan_text=""
  duration_minutes="$(printf '%s' "$json" | jq -r '.duration_minutes // empty')"
  planned_sessions="$(printf '%s' "$json" | jq -r '.planned_sessions // empty')"
  current_session="$(printf '%s' "$json" | jq -r '.current_session // empty')"
  remaining_total_seconds="$(printf '%s' "$json" | jq -r '.remaining_total_seconds // empty')"
  target_reached="$(printf '%s' "$json" | jq -r '.target_reached // false')"

  if [ -n "$duration_minutes" ]; then
    plan_text="$(plan_label "$duration_minutes" "$planned_sessions")"
    if [ "$active" = "true" ]; then
      if [ "$target_reached" = "true" ]; then
        plan_text="${plan_text%$'\n'} • complete"
      elif [ -n "$current_session" ] && [ -n "$remaining_total_seconds" ] && [ "$remaining_total_seconds" != "null" ]; then
        plan_text="${plan_text%$'\n'} • session ${current_session}/${planned_sessions:-1} • $(seconds_to_short "$remaining_total_seconds") left"
      fi
    fi
  fi

  case "$action" in
    start)
      if [ -n "$plan_text" ]; then
        printf 'started %s • %s\n' "$(seconds_to_short "$elapsed")" "$plan_text"
      else
        printf 'started %s\n' "$(seconds_to_short "$elapsed")"
      fi
      ;;
    stop)
      if [ -n "$plan_text" ]; then
        printf 'stopped %s • %s\n' "$(seconds_to_short "$elapsed")" "$plan_text"
      else
        printf 'stopped %s\n' "$(seconds_to_short "$elapsed")"
      fi
      ;;
    *)
      if [ "$active" = "true" ]; then
        if [ -n "$plan_text" ]; then
          printf 'active %s since %s • %s\n' "$(seconds_to_short "$elapsed")" "$(date -d "$started_at" '+%H:%M')" "$plan_text"
        else
          printf 'active %s since %s\n' "$(seconds_to_short "$elapsed")" "$(date -d "$started_at" '+%H:%M')"
        fi
      else
        printf 'inactive\n'
      fi
      ;;
  esac
}

mark_session_started() {
  local target_date="$1"
  local started_at="$2"
  local file
  local tmp
  file="$(day_file "$target_date")"

  ensure_day_file "$target_date" "$started_at"
  tmp="$(mktemp "${file}.XXXXXX")"
  jq --arg now "$started_at" '
    .version = (if (.version // 0) < 2 then 2 else .version end) |
    .updated_at = $now
    | .study = (
        (.study // {
          total_seconds: 0,
          session_count: 0,
          last_started_at: "",
          last_stopped_at: "",
          active_overlap_seconds: 0
        })
        | .session_count = ((.session_count // 0) + 1)
        | .last_started_at = $now
        | .active_overlap_seconds = 0
      )
  ' "$file" >"$tmp"
  mv "$tmp" "$file"
}

add_study_seconds() {
  local target_date="$1"
  local elapsed_seconds="$2"
  local stopped_at="$3"
  local file
  local tmp
  file="$(day_file "$target_date")"

  ensure_day_file "$target_date" "$stopped_at"
  tmp="$(mktemp "${file}.XXXXXX")"
  jq \
    --arg now "$stopped_at" \
    --argjson elapsed_seconds "$elapsed_seconds" \
    '
    .version = (if (.version // 0) < 2 then 2 else .version end) |
    .updated_at = $now |
    .study = (
        (.study // {
          total_seconds: 0,
          session_count: 0,
          last_started_at: "",
          last_stopped_at: "",
          active_overlap_seconds: 0
        })
        | .total_seconds = ((.total_seconds // 0) + $elapsed_seconds)
        | .last_stopped_at = $now
        | .active_overlap_seconds = 0
      )
  ' "$file" >"$tmp"
  mv "$tmp" "$file"
}

record_elapsed_session() {
  local started_at="$1"
  local stopped_at="$2"
  local start_epoch=0
  local stop_epoch=0
  local cursor_date=""
  local day_start=0
  local day_end=0
  local overlap_start=0
  local overlap_end=0
  local elapsed_seconds=0
  local next_date=""

  start_epoch="$(epoch_from_iso "$started_at")"
  stop_epoch="$(epoch_from_iso "$stopped_at")"
  if [ "$stop_epoch" -lt "$start_epoch" ]; then
    stop_epoch="$start_epoch"
  fi

  cursor_date="$(date -d "$started_at" +%F)"
  while :; do
    day_start="$(date -d "$cursor_date 00:00:00" +%s)"
    next_date="$(date -d "$cursor_date +1 day" +%F)"
    day_end="$(date -d "$next_date 00:00:00" +%s)"

    overlap_start="$start_epoch"
    if [ "$day_start" -gt "$overlap_start" ]; then
      overlap_start="$day_start"
    fi

    overlap_end="$stop_epoch"
    if [ "$day_end" -lt "$overlap_end" ]; then
      overlap_end="$day_end"
    fi

    if [ "$overlap_end" -gt "$overlap_start" ]; then
      elapsed_seconds=$((overlap_end - overlap_start))
      add_study_seconds "$cursor_date" "$elapsed_seconds" "$stopped_at"
    fi

    if [ "$day_end" -ge "$stop_epoch" ]; then
      break
    fi
    cursor_date="$next_date"
  done
}

start_session() {
  local status_json=""
  local current_now=""
  local target_date=""
  local result_json=""
  local duration_json="null"
  local session_json="null"
  local mode_json="null"

  ensure_dirs
  status_json="$(study_status_json)"
  if [ "$(printf '%s' "$status_json" | jq -r '.active')" = "true" ]; then
    notify "Study timer already running" "Current session: $(seconds_to_short "$(printf '%s' "$status_json" | jq -r '.elapsed_seconds // 0')")"
    print_result "$status_json" "status"
    return 0
  fi

  current_now="$(now_iso)"
  target_date="$(date -d "$current_now" +%F)"
  local planned_total_seconds_json="null"
  if is_positive_integer "$DURATION_MINUTES" && is_positive_integer "${SESSION_COUNT:-1}"; then
    planned_total_seconds_json=$((DURATION_MINUTES * 60 * ${SESSION_COUNT:-1}))
  fi

  mark_session_started "$target_date" "$current_now"
  jq -n \
    --arg started_at "$current_now" \
    --arg started_date "$target_date" \
    --argjson duration_minutes "$duration_json" \
    --argjson planned_sessions "$session_json" \
    --argjson planned_total_seconds "$planned_total_seconds_json" \
    --argjson mode "$mode_json" \
    '{
      version:2,
      active:true,
      started_at:$started_at,
      started_date:$started_date,
      duration_minutes:$duration_minutes,
      planned_sessions:$planned_sessions,
      planned_total_seconds:$planned_total_seconds,
      mode:$mode
    }' >"$(active_file)"

  result_json="$(study_status_json)"
  if [ -n "$DURATION_MINUTES" ]; then
    notify "Study timer started" "$(plan_label "$DURATION_MINUTES" "${SESSION_COUNT:-1}")"
  else
    notify "Study timer started" "Started at $(date -d "$current_now" '+%H:%M')"
  fi
  refresh_screen_time_cache
  refresh_waybar_screen_time
  print_result "$result_json" "start"
}

stop_session() {
  local status_json=""
  local started_at=""
  local current_now=""
  local elapsed_seconds=0
  local result_json=""

  ensure_dirs
  status_json="$(study_status_json)"
  if [ "$(printf '%s' "$status_json" | jq -r '.active')" != "true" ]; then
    notify "Study timer idle" "No active study session to stop."
    print_result "$status_json" "status"
    return 0
  fi

  started_at="$(printf '%s' "$status_json" | jq -r '.started_at')"
  elapsed_seconds="$(printf '%s' "$status_json" | jq -r '.elapsed_seconds // 0')"
  current_now="$(now_iso)"
  record_elapsed_session "$started_at" "$current_now"
  rm -f "$(active_file)"

  result_json="$(jq -n \
    --arg started_at "$started_at" \
    --arg stopped_at "$current_now" \
    --argjson elapsed_seconds "$elapsed_seconds" \
    '{active:false, started_at:$started_at, stopped_at:$stopped_at, elapsed_seconds:$elapsed_seconds}')"
  notify "Study timer stopped" "Logged $(seconds_to_short "$elapsed_seconds")"
  refresh_screen_time_cache
  refresh_waybar_screen_time
  print_result "$result_json" "stop"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    start|stop|toggle|status)
      COMMAND="$1"
      shift
      ;;
    --format)
      FORMAT="${2:-}"
      shift 2
      ;;
    --duration-minutes)
      DURATION_MINUTES="${2:-}"
      shift 2
      ;;
    --session-count)
      SESSION_COUNT="${2:-}"
      shift 2
      ;;
    --state-dir)
      STATE_DIR="${2:-}"
      shift 2
      ;;
    --mode)
      STUDY_MODE="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

case "$FORMAT" in
  text|json) ;;
  *)
    printf 'study-timer: invalid format %s\n' "$FORMAT" >&2
    exit 2
    ;;
esac

if [ -n "$DURATION_MINUTES" ] && ! is_positive_integer "$DURATION_MINUTES"; then
  printf 'study-timer: --duration-minutes must be a positive integer\n' >&2
  exit 2
fi

if [ -n "$SESSION_COUNT" ] && ! is_positive_integer "$SESSION_COUNT"; then
  printf 'study-timer: --session-count must be a positive integer\n' >&2
  exit 2
fi

if [ -n "$SESSION_COUNT" ] && [ -z "$DURATION_MINUTES" ]; then
  printf 'study-timer: --session-count requires --duration-minutes\n' >&2
  exit 2
fi

if [ -n "$DURATION_MINUTES" ] && [ -z "$SESSION_COUNT" ]; then
  SESSION_COUNT="1"
fi

case "$COMMAND" in
  start)
    start_session
    ;;
  stop)
    stop_session
    ;;
  toggle)
    if [ "$(study_status_json | jq -r '.active')" = "true" ]; then
      stop_session
    else
      start_session
    fi
    ;;
  status)
    print_result "$(study_status_json)" "status"
    ;;
esac
