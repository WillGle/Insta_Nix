#!/usr/bin/env bash

# Fetch detailed network info for Waybar tooltip
# Matches the info density of the requested QuickShell UI

# Get active wifi device
INTERFACE=$(nmcli -t -f DEVICE,TYPE device | grep wifi | cut -d: -f1 | head -n 1)

if [ -z "$INTERFACE" ]; then
    echo '{"text": "󰤮", "tooltip": "Disconnected", "class": "disconnected"}'
    exit 0
fi

# Get connection details
SSID=$(nmcli -t -f active,ssid dev wifi | grep '^yes' | cut -d: -f2)
SIGNAL=$(nmcli -t -f active,bars dev wifi | grep '^yes' | cut -d: -f2)
STRENGTH=$(nmcli -t -f active,signal dev wifi | grep '^yes' | cut -d: -f2)
SECURITY=$(nmcli -t -f active,security dev wifi | grep '^yes' | cut -d: -f2)
FREQ=$(nmcli -t -f active,freq dev wifi | grep '^yes' | cut -d: -f2)
IP=$(nmcli -t -f IP4.ADDRESS dev show "$INTERFACE" | head -n 1 | cut -d: -f2 | cut -d'/' -f1)

# Format icon based on signal strength
if [ "$STRENGTH" -ge 80 ]; then ICON="󰤨";
elif [ "$STRENGTH" -ge 60 ]; then ICON="󰤥";
elif [ "$STRENGTH" -ge 40 ]; then ICON="󰤢";
elif [ "$STRENGTH" -ge 20 ]; then ICON="󰤟";
else ICON="󰤯"; fi

TOOLTIP="<b>Network Details</b>\n"
TOOLTIP+="SSID:     $SSID\n"
TOOLTIP+="IP:       $IP\n"
TOOLTIP+="Security: $SECURITY\n"
TOOLTIP+="Signal:   $STRENGTH% ($SIGNAL)\n"
TOOLTIP+="Freq:     $FREQ"

jq -n \
  --arg text "$ICON" \
  --arg tooltip "$TOOLTIP" \
  '{"text": $text, "tooltip": $tooltip, "class": "connected"}'
