#!/usr/bin/env bash
set -euo pipefail
export LC_ALL=C
# Waybar Memory Info - Top 5 RAM consumers
# Outputs JSON for custom module

# Use a stable text prefix instead of a private-use glyph to avoid
# missing-glyph/error-icon rendering on some font stacks.
ICON_MEM="RAM"

# Get used/total RAM in GiB with 1 decimal place
used=$(free -m | awk '/Mem:/ {printf "%.1f", $3/1024}')
total=$(free -m | awk '/Mem:/ {printf "%.1f", $2/1024}')
perc=$(free | awk '/Mem:/ {printf "%.0f", $3/$2 * 100.0}')

# Get top 5 processes by memory %
top_procs=$(ps -eo comm,pmem --sort=-pmem | head -n 6 | tail -n 5 | awk '{printf "%-15s %s%%\n", $1, $2}')

class=$(awk -v p="${perc:-0}" 'BEGIN{if(p>=90) print "critical"; else if(p>=70) print "warning"; else print "normal"}')

jq -cn \
    --arg text "${ICON_MEM} ${used}G/${total}G (${perc}%)" \
    --arg tooltip "Top RAM Consumers:
------------------
$top_procs" \
    --arg class "$class" \
    '{text: $text, tooltip: $tooltip, class: $class}'
