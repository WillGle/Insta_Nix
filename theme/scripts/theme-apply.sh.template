#!/usr/bin/env bash
set -euo pipefail

MATUGEN_BIN="__MATUGEN_BIN__"
JQ_BIN="__JQ_BIN__"
SED_BIN="__SED_BIN__"
MKTEMP_BIN="__MKTEMP_BIN__"
MKDIR_BIN="__MKDIR_BIN__"
MV_BIN="__MV_BIN__"
RM_BIN="__RM_BIN__"
CMP_BIN="__CMP_BIN__"
LS_BIN="__LS_BIN__"
HEAD_BIN="__HEAD_BIN__"
NOHUP_BIN="__NOHUP_BIN__"
PKILL_BIN="__PKILL_BIN__"
PGREP_BIN="__PGREP_BIN__"
WAYBAR_BIN="__WAYBAR_BIN__"
HYPRCTL_BIN="__HYPRCTL_BIN__"

STATIC_ENV="__THEME_STATIC_ENV__"

if [ ! -f "$STATIC_ENV" ]; then
  exit 0
fi

# shellcheck disable=SC1090
. "$STATIC_ENV"

if [ "${THEME_RUNTIME_ENABLE:-0}" != "1" ]; then
  exit 0
fi

"$MKDIR_BIN" -p "$THEME_GENERATED_DIR"

TMP_DIR="$("$MKTEMP_BIN" -d)"
trap '"$RM_BIN" -rf "$TMP_DIR"' EXIT INT TERM

log() {
  printf '[theme-apply] %s\n' "$*" >&2
}

escape_sed() {
  printf '%s' "$1" | "$SED_BIN" 's/[\/&]/\\&/g'
}

strip_hex() {
  printf '%s' "${1#\#}"
}

set_fallback_palette() {
  BASE="$THEME_STATIC_BASE"
  MANTLE="$THEME_STATIC_MANTLE"
  TEXT="$THEME_STATIC_TEXT"
  SUBTEXT="$THEME_STATIC_SUBTEXT"
  ACCENT="$THEME_STATIC_ACCENT"
  SUCCESS="$THEME_STATIC_SUCCESS"
  WARNING="$THEME_STATIC_WARNING"
  ERROR="$THEME_STATIC_ERROR"
  PURPLE="$THEME_STATIC_PURPLE"
  CYAN="$THEME_STATIC_CYAN"
}

set_dynamic_palette() {
  local palette_tmp="$1"
  local base mantle text subtext accent success warning error purple cyan

  if ! "$MATUGEN_BIN" image "$THEME_WALLPAPER" -m dark -j hex -q > "$palette_tmp"; then
    return 1
  fi

  base="$("$JQ_BIN" -r '.colors.surface.default' "$palette_tmp")"
  mantle="$("$JQ_BIN" -r '.colors.surface_container.default' "$palette_tmp")"
  text="$("$JQ_BIN" -r '.colors.on_surface.default' "$palette_tmp")"
  subtext="$("$JQ_BIN" -r '.colors.on_surface_variant.default' "$palette_tmp")"
  accent="$("$JQ_BIN" -r '.colors.primary.default' "$palette_tmp")"
  success="$("$JQ_BIN" -r '.colors.secondary.default' "$palette_tmp")"
  warning="$("$JQ_BIN" -r '.colors.tertiary.default' "$palette_tmp")"
  error="$("$JQ_BIN" -r '.colors.error.default' "$palette_tmp")"
  purple="$("$JQ_BIN" -r '.colors.tertiary.default' "$palette_tmp")"
  cyan="$("$JQ_BIN" -r '.colors.secondary.default' "$palette_tmp")"

  for value in "$base" "$mantle" "$text" "$subtext" "$accent" "$success" "$warning" "$error" "$purple" "$cyan"; do
    if [ -z "$value" ] || [ "$value" = "null" ]; then
      return 1
    fi
  done

  BASE="$base"
  MANTLE="$mantle"
  TEXT="$text"
  SUBTEXT="$subtext"
  ACCENT="$accent"
  SUCCESS="$success"
  WARNING="$warning"
  ERROR="$error"
  PURPLE="$purple"
  CYAN="$cyan"
}

write_fallback_palette_json() {
  local output="$1"
  cat > "$output" <<EOF
{
  "source": "static-fallback",
  "colors": {
    "base": "$THEME_STATIC_BASE",
    "mantle": "$THEME_STATIC_MANTLE",
    "text": "$THEME_STATIC_TEXT",
    "subtext": "$THEME_STATIC_SUBTEXT",
    "accent": "$THEME_STATIC_ACCENT",
    "success": "$THEME_STATIC_SUCCESS",
    "warning": "$THEME_STATIC_WARNING",
    "error": "$THEME_STATIC_ERROR",
    "purple": "$THEME_STATIC_PURPLE",
    "cyan": "$THEME_STATIC_CYAN"
  }
}
EOF
}

render_template() {
  local input="$1"
  local output="$2"

  "$SED_BIN" \
    -e "s/__BASE__/$(escape_sed "$BASE")/g" \
    -e "s/__MANTLE__/$(escape_sed "$MANTLE")/g" \
    -e "s/__TEXT__/$(escape_sed "$TEXT")/g" \
    -e "s/__SUBTEXT__/$(escape_sed "$SUBTEXT")/g" \
    -e "s/__ACCENT__/$(escape_sed "$ACCENT")/g" \
    -e "s/__SUCCESS__/$(escape_sed "$SUCCESS")/g" \
    -e "s/__WARNING__/$(escape_sed "$WARNING")/g" \
    -e "s/__ERROR__/$(escape_sed "$ERROR")/g" \
    -e "s/__PURPLE__/$(escape_sed "$PURPLE")/g" \
    -e "s/__CYAN__/$(escape_sed "$CYAN")/g" \
    -e "s/__BASE_STRIP__/$(escape_sed "$(strip_hex "$BASE")")/g" \
    -e "s/__MANTLE_STRIP__/$(escape_sed "$(strip_hex "$MANTLE")")/g" \
    -e "s/__TEXT_STRIP__/$(escape_sed "$(strip_hex "$TEXT")")/g" \
    -e "s/__SUBTEXT_STRIP__/$(escape_sed "$(strip_hex "$SUBTEXT")")/g" \
    -e "s/__ACCENT_STRIP__/$(escape_sed "$(strip_hex "$ACCENT")")/g" \
    -e "s/__SUCCESS_STRIP__/$(escape_sed "$(strip_hex "$SUCCESS")")/g" \
    -e "s/__WARNING_STRIP__/$(escape_sed "$(strip_hex "$WARNING")")/g" \
    -e "s/__ERROR_STRIP__/$(escape_sed "$(strip_hex "$ERROR")")/g" \
    -e "s/__PURPLE_STRIP__/$(escape_sed "$(strip_hex "$PURPLE")")/g" \
    -e "s/__CYAN_STRIP__/$(escape_sed "$(strip_hex "$CYAN")")/g" \
    -e "s/__UI_FONT__/$(escape_sed "$THEME_UI_FONT")/g" \
    -e "s/__UI_FONT_SIZE__/$(escape_sed "$THEME_UI_FONT_SIZE")/g" \
    -e "s/__MONO_FONT__/$(escape_sed "$THEME_MONO_FONT")/g" \
    -e "s/__MONO_FONT_SIZE__/$(escape_sed "$THEME_MONO_FONT_SIZE")/g" \
    -e "s/__LOCK_FONT__/$(escape_sed "$THEME_LOCK_FONT")/g" \
    -e "s/__LOCK_FONT_BOLD__/$(escape_sed "$THEME_LOCK_FONT_BOLD")/g" \
    -e "s/__LOCK_CLOCK_SIZE__/$(escape_sed "$THEME_LOCK_CLOCK_SIZE")/g" \
    -e "s/__LOCK_TEXT_SIZE__/$(escape_sed "$THEME_LOCK_TEXT_SIZE")/g" \
    -e "s#__WALLPAPER_PATH__#$(escape_sed "$THEME_WALLPAPER")#g" \
    "$input" > "$output"
}

apply_if_changed() {
  local src="$1"
  local dest="$2"
  local changed_var="$3"

  if [ ! -f "$dest" ] || ! "$CMP_BIN" -s "$src" "$dest"; then
    "$MV_BIN" "$src" "$dest"
    printf -v "$changed_var" '1'
  else
    "$RM_BIN" -f "$src"
  fi
}

ensure_waybar_running() {
  if ! "$PGREP_BIN" -x waybar >/dev/null 2>&1; then
    "$NOHUP_BIN" "$WAYBAR_BIN" >/dev/null 2>&1 &
    sleep 0.2
  fi
}

PALETTE_TMP="$TMP_DIR/palette.json"
PALETTE_SOURCE="dynamic"

if [ ! -f "$THEME_WALLPAPER" ]; then
  log "wallpaper not found, using static fallback palette"
  PALETTE_SOURCE="fallback"
  set_fallback_palette
  write_fallback_palette_json "$PALETTE_TMP"
elif ! set_dynamic_palette "$PALETTE_TMP"; then
  log "matugen failed or returned an invalid palette, using static fallback palette"
  PALETTE_SOURCE="fallback"
  set_fallback_palette
  write_fallback_palette_json "$PALETTE_TMP"
fi

render_template "$THEME_TEMPLATE_DIR/waybar.css.template" "$TMP_DIR/waybar.css"
render_template "$THEME_TEMPLATE_DIR/rofi.rasi.template" "$TMP_DIR/rofi.rasi"
render_template "$THEME_TEMPLATE_DIR/hyprlock.conf.template" "$TMP_DIR/hyprlock.conf"
render_template "$THEME_TEMPLATE_DIR/hyprland-decoration.conf.template" "$TMP_DIR/hyprland-decoration.conf"
render_template "$THEME_TEMPLATE_DIR/nvim-colors.lua.template" "$TMP_DIR/nvim-matugen.lua"

waybar_changed=0
hyprland_changed=0

apply_if_changed "$TMP_DIR/waybar.css" "$THEME_GENERATED_DIR/waybar.css" waybar_changed
apply_if_changed "$TMP_DIR/rofi.rasi" "$THEME_GENERATED_DIR/rofi.rasi" rofi_changed
apply_if_changed "$TMP_DIR/hyprlock.conf" "$THEME_GENERATED_DIR/hyprlock.conf" hyprlock_changed
apply_if_changed "$TMP_DIR/hyprland-decoration.conf" "$THEME_GENERATED_DIR/hyprland-decoration.conf" hyprland_changed
apply_if_changed "$TMP_DIR/nvim-matugen.lua" "$THEME_GENERATED_DIR/nvim-matugen.lua" nvim_changed
apply_if_changed "$PALETTE_TMP" "$THEME_GENERATED_DIR/palette.json" palette_changed

if "$PGREP_BIN" -x waybar >/dev/null 2>&1; then
  if [ "$waybar_changed" -eq 1 ]; then
    "$PKILL_BIN" -SIGUSR2 waybar >/dev/null 2>&1 || true
  fi
else
  ensure_waybar_running
fi

if [ "$hyprland_changed" -eq 1 ]; then
  if [ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] && [ -d /tmp/hypr ]; then
    HYPRLAND_INSTANCE_SIGNATURE="$("$LS_BIN" -1t /tmp/hypr 2>/dev/null | "$HEAD_BIN" -n1 || true)"
    export HYPRLAND_INSTANCE_SIGNATURE
  fi
  "$HYPRCTL_BIN" reload config-only >/dev/null 2>&1 || true
fi

if [ "$PALETTE_SOURCE" = "fallback" ]; then
  log "applied static fallback palette"
fi
