#!/usr/bin/env bash
set -euo pipefail

HYPRLOCK_BIN="__HYPRLOCK_BIN__"
GENERATED_DIR="__THEME_GENERATED_DIR__"
CONFIG="${GENERATED_DIR}/hyprlock.conf"

if [ ! -s "$CONFIG" ]; then
  echo "theme-lock: missing generated Hyprlock config at $CONFIG" >&2
  exit 1
fi

exec "$HYPRLOCK_BIN" --config "$CONFIG" "$@"
