/* =========================================================================
   Waybar Theme – rendered from /etc/nixos/theme/templates/waybar.css.template
   ========================================================================= */

@define-color base __BASE__;
@define-color mantle __MANTLE__;
@define-color text __TEXT__;
@define-color subtext __SUBTEXT__;
@define-color accent __ACCENT__;
@define-color success __SUCCESS__;
@define-color warning #d29922;
@define-color error #f85149;
@define-color purple __PURPLE__;
@define-color cyan __CYAN__;

@define-color battery-eco #00ffcc;

@keyframes blink {
  to {
    background-color: @error;
    color: @base;
  }
}

* {
  border: none;
  border-radius: 0;
  padding: 0 5px;
  margin: 0;
  font-family: "__UI_FONT__", monospace;
  font-weight: bold;
  font-size: __UI_FONT_SIZE__px;
  background: transparent;
  color: @text;
  transition: none;
}

window#waybar {
  background: @base;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  min-height: 28px;
}

#workspaces button,
#clock,
#tray,
#pulseaudio,
#custom-screen_time,
#custom-memory_info,
#custom-network_info,
#custom-apu_info,
#custom-power_flow,
#custom-power_profile,
#custom-battery_mode,
#custom-refresh_rate,
#custom-atomic_note,
tooltip,
menuitem,
.popup menuitem {
  margin: 0;
  padding-left: 10px;
  padding-right: 10px;
  font-family: "__UI_FONT__", monospace;
  font-weight: bold;
  font-size: __UI_FONT_SIZE__px;
}

#workspaces button,
#clock,
#tray,
#pulseaudio,
#custom-screen_time,
#custom-memory_info,
#custom-network_info,
#custom-apu_info,
#custom-power_flow,
#custom-power_profile,
#custom-battery_mode,
#custom-refresh_rate,
#custom-atomic_note {
  border-radius: 0;
  padding-top: 0;
  padding-bottom: 0;
}

#workspaces button {
  color: @subtext;
}

#workspaces button.focused {
  color: @accent;
  background: rgba(255, 255, 255, 0.05);
  border-bottom: 2px solid @accent;
}

#workspaces button:hover {
  background: rgba(255, 255, 255, 0.1);
  color: @text;
}

#clock,
#tray,
#pulseaudio,
#custom-screen_time,
#custom-memory_info,
#custom-network_info,
#custom-apu_info,
#custom-power_flow,
#custom-power_profile,
#custom-battery_mode,
#custom-refresh_rate,
#custom-atomic_note {
  background: rgba(255, 255, 255, 0.05);
  border-left: 1px solid rgba(255, 255, 255, 0.05);
}

tooltip,
menu,
.menu,
.popup {
  background-color: @mantle;
  color: @text;
  border: 1px solid @accent;
  border-radius: 6px;
}

tooltip label {
  font-family: "JetBrainsMono Nerd Font Mono", monospace;
  font-weight: normal;
  padding: 0;
}

#clock tooltip label {
  font-family: "JetBrainsMono Nerd Font Mono", monospace;
  font-weight: normal;
  font-size: 15px;
}

tooltip *,
tooltip label,
menu *,
.menu *,
.popup * {
  color: @text;
  font-size: __UI_FONT_SIZE__px;
}

menuitem,
.popup menuitem {
  padding-top: 6px;
  padding-bottom: 6px;
  border-radius: 4px;
}

#clock:hover,
#tray:hover,
#pulseaudio:hover,
#custom-screen_time:hover,
#custom-memory_info:hover,
#custom-network_info:hover,
#custom-apu_info:hover,
#custom-power_flow:hover,
#custom-power_profile:hover,
#custom-battery_mode:hover,
#custom-refresh_rate:hover,
#custom-atomic_note:hover,
#workspaces button:hover,
menuitem:hover,
.popup menuitem:hover {
  background: rgba(255, 255, 255, 0.1);
  color: @text;
}

#custom-apu_info.warm {
  color: @warning;
}

#custom-apu_info.hot {
  color: @error;
  font-weight: bold;
}

#custom-apu_info.critical {
  background-color: @error;
  color: @base;
  animation-name: blink;
  animation-duration: 0.5s;
  animation-direction: alternate;
  animation-iteration-count: infinite;
}

#custom-apu_info.medium,
#custom-power_flow.medium {
  border-top: 2px solid @warning;
}

#custom-apu_info.high,
#custom-power_flow.high {
  color: @error;
  font-weight: bold;
  border-top: 2px solid @error;
}

#custom-power_flow.charging {
  color: @battery-eco;
  border-bottom: 2px solid @battery-eco;
}

#custom-power_flow.critical {
  color: @error;
  border-bottom: 2px solid @error;
}

#custom-memory_info.warning {
  color: @warning;
}

#custom-memory_info.critical {
  color: @error;
  font-weight: bold;
}

#custom-network_info.disconnected,
#custom-network_info.disabled {
  color: @subtext;
}

#custom-network_info.ethernet {
  color: @accent;
}

#pulseaudio.muted {
  color: @subtext;
}

#custom-screen_time.studying {
  color: @battery-eco;
  border-bottom: 2px solid @battery-eco;
}

#custom-screen_time.medium {
  color: @warning;
}

#custom-screen_time.high {
  color: @error;
  border-bottom: 2px solid @error;
}

#custom-screen_time.idle {
  color: @subtext;
}

#custom-power_profile.perf {
  color: @error;
  border-bottom: 2px solid @error;
}

#custom-power_profile.saver {
  color: @battery-eco;
  border-bottom: 2px solid @battery-eco;
}

#custom-battery_mode.reserve-on {
  color: @battery-eco;
  border-bottom: 2px solid @battery-eco;
}

#custom-battery_mode.reserve-off,
#custom-battery_mode.reserve-unknown {
  color: @warning;
  border-bottom: 2px solid @warning;
}

tooltip {
  padding-top: 6px;
  padding-bottom: 6px;
}

menu,
.menu,
.popup {
  margin: 0;
  padding: 4px 0;
}

#custom-atomic_note {
  color: @accent;
}

#custom-atomic_note.critical,
#custom-atomic_note.urgent {
  color: @error;
  border-bottom: 2px solid @error;
}

#custom-atomic_note.high,
#custom-atomic_note.warning {
  color: @warning;
  border-bottom: 2px solid @warning;
}

#custom-atomic_note.moderate {
  color: @accent;
  border-bottom: 2px solid @accent;
}

#custom-atomic_note.low {
  color: @success;
  border-bottom: 2px solid @success;
}

#custom-atomic_note.empty {
  color: @subtext;
}
