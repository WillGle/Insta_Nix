* {
  base: __BASE__;
  mantle: __MANTLE__;
  text: __TEXT__;
  subtext: __SUBTEXT__;
  accent: __ACCENT__;
  success: __SUCCESS__;
  warning: __WARNING__;
  error: __ERROR__;
  purple: __PURPLE__;
  cyan: __CYAN__;
  
  background-color: transparent;
  text-color: @text;
  font: "__UI_FONT__ 10";
  mono-font: "__MONO_FONT__ 10";
}

window {
  width:            45%;
  border:           2px;
  border-color:     @accent;
  border-radius:    14px;
  background-color: @base;
  padding:          14px;
}

mainbox {
  spacing:          8px;
  padding:          10px;
  children:         [ inputbar, message, listview ];
  background-color: transparent;
}

inputbar {
  enabled:          true;
  margin:           0 0 10px 0;
  spacing:          10px;
  padding:          4px;
  children:         [ prompt, entry ];
  background-color: transparent;
}

prompt {
  background-color: @accent;
  text-color:       @base;
  padding:          4px 12px;
  border-radius:    8px;
  font:             "JetBrainsMono Nerd Font Bold 10";
}

entry {
  text-color:       @text;
  font:             @mono-font;
  placeholder:      "Search...";
  placeholder-color: @subtext;
  vertical-align:   0.5;
  padding:          0 8px;
}

message {
  enabled:          true;
  margin:           5px 0;
  padding:          12px;
  border-radius:    10px;
  background-color: @mantle;
  text-color:       @text;
}

textbox {
  markup:           true;
  text-color:       @text;
  background-color: transparent;
}

listview {
  lines:            8;
  columns:          1;
  fixed-height:     false;
  spacing:          8px;
  scrollbar:        false;
  background-color: transparent;
  padding:          0px;
}

element {
  spacing:          12px;
  padding:          8px 12px;
  margin:           0px;
  border-radius:    10px;
  background-color: transparent;
  text-color:       @text;
  children:         [ element-icon, element-text ];
}

element selected {
  background-color: @accent;
  text-color:       @base;
}

element-icon {
  size:             1.2em;
  background-color: transparent;
  vertical-align:   0.0;
}

element-text {
  markup:           true;
  text-color:       inherit;
  vertical-align:   0.0;
}

error-message {
  padding: 10px;
  border-radius: 8px;
  border: 1px;
  border-color: @error;
  background-color: @mantle;
  text-color: @error;
}
